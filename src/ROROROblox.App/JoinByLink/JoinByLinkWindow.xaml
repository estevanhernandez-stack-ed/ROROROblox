<Window x:Class="ROROROblox.App.JoinByLink.JoinByLinkWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Join by link"
        Height="320" Width="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Window.Resources>
    </Window.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Join by link"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource CyanBrush}" />
                <TextBlock x:Name="AccountSubtitle"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource WhiteBrush}"
                           Margin="8,0,0,0" />
            </StackPanel>
            <TextBlock Text="Paste a Roblox game URL or a private server share link. We figure out which kind it is."
                       FontSize="11"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <TextBox Grid.Row="1" x:Name="UrlInput"
                 Padding="10,8" FontSize="12" Margin="0,18,0,0"
                 Background="{DynamicResource RowBgBrush}"
                 Foreground="{DynamicResource WhiteBrush}"
                 BorderBrush="{DynamicResource DividerBrush}"
                 BorderThickness="1"
                 VerticalContentAlignment="Center"
                 TextChanged="OnUrlChanged" />

        <Border Grid.Row="2" Margin="0,12,0,0"
                Background="{DynamicResource RowBgBrush}"
                CornerRadius="6"
                Padding="12,10"
                Visibility="Collapsed"
                x:Name="PreviewBorder">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="PreviewLabel"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource CyanBrush}"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="PreviewDetail"
                           FontSize="11"
                           Foreground="{DynamicResource WhiteBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" x:Name="StatusText"
                   FontSize="11"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="14,8" Margin="0,0,8,0"
                    Background="{DynamicResource NavyBrush}"
                    Foreground="{DynamicResource WhiteBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="1"
                    IsCancel="True"
                    Click="OnCancelClick" />
            <Button x:Name="LaunchButton"
                    Content="Launch"
                    Padding="18,8"
                    Background="{DynamicResource CyanBrush}"
                    Foreground="{DynamicResource NavyBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="OnLaunchClick" />
        </StackPanel>
    </Grid>
</Window>
