<Window x:Class="ROROROblox.App.JoinByLink.JoinByLinkWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Join by link"
        Height="320" Width="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0F1F31"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="DividerBrush" Color="#1F3149" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9AA8B8" />
        <SolidColorBrush x:Key="CyanBrush" Color="#17D4FA" />
        <SolidColorBrush x:Key="MagentaBrush" Color="#F22F89" />
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="NavyBrush" Color="#0F1F31" />
        <SolidColorBrush x:Key="RowBgBrush" Color="#15263A" />
    </Window.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Join by link"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource CyanBrush}" />
                <TextBlock x:Name="AccountSubtitle"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource WhiteBrush}"
                           Margin="8,0,0,0" />
            </StackPanel>
            <TextBlock Text="Paste a Roblox game URL or a private server share link. We figure out which kind it is."
                       FontSize="11"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <TextBox Grid.Row="1" x:Name="UrlInput"
                 Padding="10,8" FontSize="12" Margin="0,18,0,0"
                 Background="{StaticResource RowBgBrush}"
                 Foreground="{StaticResource WhiteBrush}"
                 BorderBrush="{StaticResource DividerBrush}"
                 BorderThickness="1"
                 VerticalContentAlignment="Center"
                 TextChanged="OnUrlChanged" />

        <Border Grid.Row="2" Margin="0,12,0,0"
                Background="{StaticResource RowBgBrush}"
                CornerRadius="6"
                Padding="12,10"
                Visibility="Collapsed"
                x:Name="PreviewBorder">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="PreviewLabel"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource CyanBrush}"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="PreviewDetail"
                           FontSize="11"
                           Foreground="{StaticResource WhiteBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" x:Name="StatusText"
                   FontSize="11"
                   Foreground="{StaticResource MutedTextBrush}"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="14,8" Margin="0,0,8,0"
                    Background="{StaticResource NavyBrush}"
                    Foreground="{StaticResource WhiteBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    IsCancel="True"
                    Click="OnCancelClick" />
            <Button x:Name="LaunchButton"
                    Content="Launch"
                    Padding="18,8"
                    Background="{StaticResource CyanBrush}"
                    Foreground="{StaticResource NavyBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="OnLaunchClick" />
        </StackPanel>
    </Grid>
</Window>
