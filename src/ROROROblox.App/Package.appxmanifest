<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10" xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10" xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities" IgnorableNamespaces="uap rescap">
    <!-- Identity: production values from the Partner Center reservation for ROROROblox under
         626 Labs LLC (Store ID 9NMJCS390KWB). Update via scripts/finalize-store-build.ps1 on
         every release; it patches Name / Publisher / Version / PublisherDisplayName in one
         shot and validates the inputs before touching the file.
         For sideload builds (scripts/build-msix.ps1 -Sideload), the Publisher CN must instead
         match the self-signed cert generated by scripts/generate-dev-cert.ps1; pass
         -RestoreManifest on the previous finalize run, or hand-edit before the sideload build.
         Version increments on every release submission; align with Velopack release tags. -->
    <Identity Name="626LabsLLC.RoRoRoBlox" Publisher="CN=177BCE59-0966-4975-9962-10E36652141F" Version="1.1.2.0" ProcessorArchitecture="x64" />
    <Properties>
        <DisplayName>RORORO</DisplayName>
        <PublisherDisplayName>626Labs LLC</PublisherDisplayName>
        <Logo>Package\Logos\StoreLogo.png</Logo>
        <!-- Description: surfaces in package metadata + Store listing fallback. Trademark
             disclaimer is required for nominative-use of "Roblox" per Sanduhr Store playbook
             (10.1.4.4.a). Long-form disclaimer lives in docs/store/listing-copy.md and the
             privacy policy; this is the abbreviated form that fits the manifest field. -->
        <Description>Multi-launcher for Windows. Run multiple Roblox clients side by side, signed in as different saved accounts. "Roblox" is a trademark of Roblox Corporation; RORORO is an independent third-party tool, not affiliated with Roblox Corporation. A 626 Labs product.</Description>
    </Properties>
    <Dependencies>
        <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.22000.0" MaxVersionTested="10.0.26100.0" />
    </Dependencies>
    <Resources>
        <Resource Language="en-us" />
    </Resources>
    <Applications>
        <Application Id="ROROROblox" Executable="ROROROblox.App.exe" EntryPoint="Windows.FullTrustApplication">
            <uap:VisualElements DisplayName="RORORO" Description="Multi-launcher for Windows. Run multiple Roblox clients side by side." BackgroundColor="#0F1F31" Square150x150Logo="Package\Logos\Square150x150Logo.png" Square44x44Logo="Package\Logos\Square44x44Logo.png">
                <uap:DefaultTile Wide310x150Logo="Package\Logos\Wide310x150Logo.png" Square71x71Logo="Package\Logos\Square71x71Logo.png" Square310x310Logo="Package\Logos\Square310x310Logo.png">
                    <uap:ShowNameOnTiles>
                        <uap:ShowOn Tile="square150x150Logo" />
                        <uap:ShowOn Tile="wide310x150Logo" />
                        <uap:ShowOn Tile="square310x310Logo" />
                    </uap:ShowNameOnTiles>
                </uap:DefaultTile>
                <uap:SplashScreen Image="Package\Logos\SplashScreen.png" BackgroundColor="#0F1F31" />
            </uap:VisualElements>
        </Application>
    </Applications>
    <Capabilities>
        <!-- runFullTrust is required for a WPF desktop app that calls Process.Start of the
             roblox-player: protocol handler. We deliberately omit broadFileSystemAccess Ã¢â‚¬â€
             accounts.dat lives in our own LocalAppData folder; no other user-content access. -->
        <rescap:Capability Name="runFullTrust" />
    </Capabilities>
</Package>