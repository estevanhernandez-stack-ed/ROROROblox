<Window x:Class="ROROROblox.App.Settings.SettingsWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ROROROblox -- Settings"
        Height="380" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1F31">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="20" FontWeight="Bold"
                   Foreground="#17D4FA" />

        <TextBlock Grid.Row="1"
                   Text="Default Roblox game URL"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="#FFFFFF"
                   Margin="0,24,0,4" />

        <TextBlock Grid.Row="2"
                   FontSize="11"
                   Foreground="#9AA8B8"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8">
            <Run Text="When you click " />
            <Run Text="Launch As" FontWeight="SemiBold" />
            <Run Text=", ROROROblox launches Roblox into this game by default. Paste any roblox.com/games/&lt;id&gt;/&lt;name&gt; URL." />
        </TextBlock>

        <TextBox Grid.Row="3"
                 x:Name="PlaceUrlInput"
                 FontSize="12"
                 FontFamily="Consolas"
                 Padding="10,8"
                 Background="#15263A"
                 Foreground="#FFFFFF"
                 BorderBrush="#1F3149"
                 CaretBrush="#17D4FA"
                 BorderThickness="1" />

        <TextBlock Grid.Row="4"
                   FontSize="10"
                   Foreground="#9AA8B8"
                   Opacity="0.7"
                   TextWrapping="Wrap"
                   Margin="0,12,0,0">
            <Run Text="Tip: open Roblox in your browser, find a game you want as your default, copy the URL from the address bar, paste it here. Example: https://www.roblox.com/games/920587237/Adopt-Me" />
        </TextBlock>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0"
                    Background="#0F1F31" Foreground="#FFFFFF" BorderBrush="#5A6982" BorderThickness="1"
                    Click="OnCancelClick" />
            <Button Content="Save" Padding="16,8" IsDefault="True"
                    Background="#17D4FA" Foreground="#0F1F31" BorderThickness="0"
                    FontWeight="Bold"
                    Click="OnSaveClick" />
        </StackPanel>
    </Grid>
</Window>
