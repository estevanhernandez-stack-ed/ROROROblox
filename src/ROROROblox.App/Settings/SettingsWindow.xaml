<Window x:Class="ROROROblox.App.Settings.SettingsWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:ROROROblox.Core;assembly=ROROROblox.Core"
        Title="RoRoRo -- Library"
        Height="820" Width="700"
        MinHeight="600" MinWidth="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Window.Resources>
        <DataTemplate DataType="{x:Type core:GameSearchResult}">
            <Border Margin="0,0,0,6" Padding="10,8" CornerRadius="6"
                    Background="{DynamicResource RowBgBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                            Background="{DynamicResource NavyBrush}" ClipToBounds="True"
                            VerticalAlignment="Center">
                        <Image Source="{Binding IconUrl}" Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WhiteBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding CreatorName, StringFormat='by {0}'}"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock Text="  -  "
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Opacity="0.5" />
                            <TextBlock Text="{Binding PlayerCount, StringFormat='{}{0:N0} playing'}"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="2" Content="+ Add"
                            Tag="{Binding}"
                            Click="OnAddSearchResultClick"
                            Padding="12,6"
                            Background="{DynamicResource CyanBrush}"
                            Foreground="{DynamicResource NavyBrush}"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            FontSize="11" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type core:FavoriteGame}">
            <Border Margin="0,0,0,8" Padding="14,10"
                    CornerRadius="8"
                    Background="{DynamicResource RowBgBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource CyanBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <!-- v1.3.x — right-click rename context menu (item 7 surface 5).
                     Tag="{Binding}" passes the full FavoriteGame to the click handler. -->
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Rename…"
                                  Tag="{Binding}"
                                  Click="OnRenameGameClick" />
                        <MenuItem Header="Reset name"
                                  Tag="{Binding}"
                                  Click="OnResetGameNameClick">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LocalName}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="6"
                            Background="{DynamicResource NavyBrush}" ClipToBounds="True"
                            VerticalAlignment="Center">
                        <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <!-- v1.3.x — RenderName = LocalName ?? Name. -->
                            <TextBlock Text="{Binding RenderName}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WhiteBrush}" />
                            <Border Background="{DynamicResource CyanBrush}" CornerRadius="3"
                                    Margin="10,2,0,0" Padding="6,1"
                                    Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="DEFAULT"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource NavyBrush}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding PlaceId, StringFormat='Place ID {0}'}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Set default"
                                Tag="{Binding PlaceId}"
                                Click="OnSetDefaultClick"
                                Padding="10,6" Margin="0,0,8,0"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11"
                                Visibility="{Binding IsDefault, Converter={StaticResource InverseBoolConverter}}" />
                        <!-- v1.3.x — visible Rename button. Right-click context menu still works
                             for users who find that first; this is the discoverable surface. -->
                        <Button Content="Rename"
                                Tag="{Binding}"
                                Click="OnRenameGameClick"
                                Padding="10,6" Margin="0,0,8,0"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11"
                                ToolTip="Give this game a custom name shown only in RoRoRo. The Roblox-side name stays untouched." />
                        <Button Content="Remove"
                                Tag="{Binding PlaceId}"
                                Click="OnRemoveClick"
                                Padding="10,6"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- v1.3.x — saved private server row template. Visible Rename button + right-click. -->
        <DataTemplate DataType="{x:Type core:SavedPrivateServer}">
            <Border Margin="0,0,0,8" Padding="14,10"
                    CornerRadius="8"
                    Background="{DynamicResource RowBgBrush}">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Rename…"
                                  Tag="{Binding}"
                                  Click="OnRenameServerClick" />
                        <MenuItem Header="Reset name"
                                  Tag="{Binding}"
                                  Click="OnResetServerNameClick">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LocalName}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="6"
                            Background="{DynamicResource NavyBrush}" ClipToBounds="True"
                            VerticalAlignment="Center">
                        <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <!-- v1.3.x — RenderName = LocalName ?? Name. -->
                            <TextBlock Text="{Binding RenderName}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WhiteBrush}" />
                            <Border Background="{DynamicResource MagentaBrush}" CornerRadius="3"
                                    Margin="10,2,0,0" Padding="6,1">
                                <TextBlock Text="PRIVATE"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource WhiteBrush}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding PlaceName}"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- v1.3.x — visible Rename button. Spec §10 — Library is the discoverable
                             home for renaming saved private servers; right-click works too. -->
                        <Button Content="Rename"
                                Tag="{Binding}"
                                Click="OnRenameServerClick"
                                Padding="10,6" Margin="0,0,8,0"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11"
                                ToolTip="Give this server a custom name shown only in RoRoRo." />
                        <Button Content="Remove"
                                Tag="{Binding Id}"
                                Click="OnRemoveServerClick"
                                Padding="10,6"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="InverseBoolToVisibilityStyle" TargetType="UIElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDefault}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Title -->
            <RowDefinition Height="Auto" />  <!-- Search box -->
            <RowDefinition Height="Auto" />  <!-- Search results -->
            <RowDefinition Height="Auto" />  <!-- Or paste URL -->
            <RowDefinition Height="Auto" />  <!-- Add status -->
            <RowDefinition Height="Auto" />  <!-- Saved games header -->
            <RowDefinition Height="2*" />    <!-- Saved games list -->
            <RowDefinition Height="Auto" />  <!-- Saved servers header -->
            <RowDefinition Height="*" />     <!-- Saved servers list -->
            <RowDefinition Height="Auto" />  <!-- Footer -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="RoRoRo"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource CyanBrush}" />
                <TextBlock Text=" / "
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource MagentaBrush}" />
                <TextBlock Text="Library"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource WhiteBrush}" />
            </StackPanel>
            <TextBlock Text="Saved games + private servers. The game marked DEFAULT is what Launch As uses. Click Rename on any row to give it a custom name (Roblox-side names stay untouched)."
                       FontSize="11"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="SearchInput"
                     FontSize="13"
                     Padding="10,8"
                     Background="{DynamicResource RowBgBrush}"
                     Foreground="{DynamicResource WhiteBrush}"
                     BorderBrush="{DynamicResource DividerBrush}"
                     CaretBrush="{DynamicResource CyanBrush}"
                     BorderThickness="1"
                     KeyDown="OnSearchKeyDown"
                     ToolTip="Search Roblox games by name. Enter to search." />
            <Button Grid.Column="1" x:Name="SearchButton" Content="Search"
                    Padding="14,8" Margin="8,0,0,0"
                    Background="{DynamicResource CyanBrush}"
                    Foreground="{DynamicResource NavyBrush}"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Click="OnSearchClick" />
        </Grid>

        <Border Grid.Row="2" x:Name="SearchResultsContainer"
                Margin="0,8,0,0"
                MaxHeight="220"
                Visibility="Collapsed"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SearchResultsList" />
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="UrlInput"
                     FontSize="12"
                     FontFamily="Consolas"
                     Padding="10,8"
                     Background="{DynamicResource RowBgBrush}"
                     Foreground="{DynamicResource WhiteBrush}"
                     BorderBrush="{DynamicResource DividerBrush}"
                     CaretBrush="{DynamicResource CyanBrush}"
                     BorderThickness="1"
                     ToolTip="Or paste a roblox.com/games/&lt;id&gt;/&lt;name&gt; URL or place id" />
            <Button Grid.Column="1" x:Name="AddButton" Content="+ Add by URL"
                    Padding="14,8" Margin="8,0,0,0"
                    Background="{DynamicResource NavyBrush}"
                    Foreground="{DynamicResource WhiteBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="1"
                    FontSize="12"
                    Click="OnAddClick" />
        </Grid>

        <TextBlock Grid.Row="4" x:Name="StatusText"
                   FontSize="11"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap" />

        <TextBlock Grid.Row="5"
                   Text="Saved games"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Margin="0,20,0,8" />

        <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Visible">
            <Grid>
                <ItemsControl x:Name="FavoritesList" />
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            x:Name="EmptyState">
                    <TextBlock Text="No saved games yet."
                               FontSize="13"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Search above or paste a Roblox game URL to add your first one."
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               Opacity="0.7" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- v1.3.x — saved private servers section. Add path stays in Squad Launch sheet
             ("Add by URL" pasting + auto-launch); this surface manages existing entries. -->
        <TextBlock Grid.Row="7"
                   Text="Saved private servers"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Margin="0,16,0,8" />

        <ScrollViewer Grid.Row="8" VerticalScrollBarVisibility="Visible">
            <Grid>
                <ItemsControl x:Name="ServersList" />
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            x:Name="ServersEmptyState">
                    <TextBlock Text="No saved private servers."
                               FontSize="13"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Use the Private server toolbar button to add one."
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               Opacity="0.7" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Button Grid.Row="9" Content="Close" Padding="16,8"
                HorizontalAlignment="Right" Margin="0,12,0,0"
                Background="{DynamicResource NavyBrush}"
                Foreground="{DynamicResource WhiteBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="1"
                IsCancel="True"
                Click="OnCloseClick" />
    </Grid>
</Window>
