<Window x:Class="ROROROblox.App.Settings.DiscordIntegrationsWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RORORO -- Discord integrations"
        Height="640" Width="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Discord"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource CyanBrush}" />
                <TextBlock Text=" / "
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource MagentaBrush}" />
                <TextBlock Text="Integrations"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource WhiteBrush}" />
            </StackPanel>
            <TextBlock Text="Show ROROROblox in your Discord status, and post clan-channel updates."
                       FontSize="11"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,24,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Layer 1 — rich-presence master toggle -->
                <Border Background="{DynamicResource RowBgBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <CheckBox x:Name="RichPresenceToggle"
                                  Foreground="{DynamicResource WhiteBrush}"
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Click="OnRichPresenceToggle">
                            <TextBlock Text="Show RORORO in your Discord status." />
                        </CheckBox>
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="22,4,0,0"
                                   Text="When enabled, your Discord profile shows you have ROROROblox running. No account names, no Roblox usernames -- only that the app is open and how many accounts are active." />
                    </StackPanel>
                </Border>

                <!-- Layer 3 — clan-channel webhook -->
                <Border Background="{DynamicResource RowBgBrush}" CornerRadius="8" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Clan channel webhook"
                                   Foreground="{DynamicResource WhiteBrush}"
                                   FontSize="13" FontWeight="SemiBold" />
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,8"
                                   Text="Optional. Paste a webhook URL from your clan's Discord channel admin to opt in to broadcast events." />

                        <TextBlock Text="Webhook URL"
                                   Foreground="{DynamicResource WhiteBrush}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Margin="0,4,0,4" />
                        <TextBox x:Name="WebhookUrlBox"
                                 Background="{DynamicResource NavyBrush}"
                                 Foreground="{DynamicResource WhiteBrush}"
                                 BorderBrush="{DynamicResource DividerBrush}"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 FontSize="12"
                                 FontFamily="Consolas"
                                 TextChanged="OnWebhookUrlChanged"
                                 LostFocus="OnWebhookUrlLostFocus" />
                        <TextBlock x:Name="WebhookUrlHint"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,8"
                                   Text="Get this from your clan's Discord channel admin." />

                        <TextBlock Text="Post to clan channel when:"
                                   Foreground="{DynamicResource WhiteBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="0,8,0,4" />

                        <CheckBox x:Name="OnLaunchToggle"
                                  Foreground="{DynamicResource WhiteBrush}"
                                  FontSize="12"
                                  Margin="0,2,0,2"
                                  Click="OnEventToggle">
                            <TextBlock Text="I start ROROROblox" />
                        </CheckBox>
                        <CheckBox x:Name="OnPrivateServerJoinToggle"
                                  Foreground="{DynamicResource WhiteBrush}"
                                  FontSize="12"
                                  Margin="0,2,0,2"
                                  Click="OnEventToggle">
                            <TextBlock Text="I join a private server" />
                        </CheckBox>
                        <CheckBox x:Name="OnNAccountsToggle"
                                  Foreground="{DynamicResource WhiteBrush}"
                                  FontSize="12"
                                  Margin="0,2,0,2"
                                  Click="OnEventToggle">
                            <TextBlock Text="I have 4+ accounts running at once" />
                        </CheckBox>

                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   Text="All defaults OFF. Each clanmate opts in separately." />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Close" Padding="22,8"
                    Background="{DynamicResource CyanBrush}"
                    Foreground="{DynamicResource NavyBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
