<Window x:Class="ROROROblox.App.About.AboutWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ROROROblox"
        Height="420" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1F31"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="DividerBrush" Color="#1F3149" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9AA8B8" />
        <SolidColorBrush x:Key="CyanBrush" Color="#17D4FA" />
        <SolidColorBrush x:Key="MagentaBrush" Color="#F22F89" />
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="NavyBrush" Color="#0F1F31" />
    </Window.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Image Source="/ROROROblox.App;component/Tray/Resources/tray-on.ico"
                   Width="48" Height="48" Margin="0,0,16,0" />
            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ROROROblox"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource CyanBrush}" />
                    <TextBlock Text=" / "
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource MagentaBrush}" />
                    <TextBlock x:Name="VersionText"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource WhiteBrush}" />
                </StackPanel>
                <TextBlock Text="A 626 Labs product. Imagine Something Else."
                           FontSize="11"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,24,0,0" Padding="16,14"
                Background="#15263A" CornerRadius="8">
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource WhiteBrush}">
                Run multiple Roblox clients side by side, signed in as different saved accounts.
                Holds the Roblox singleton mutex so subsequent clients don't fight for it; uses
                Roblox's documented authentication-ticket flow for per-account launches. Clean
                reimplementation; not a fork.
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="Links" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource CyanBrush}" Margin="0,0,0,6" />
            <TextBlock FontSize="11" Margin="0,0,0,4">
                <Hyperlink x:Name="RepoLink" Foreground="{StaticResource WhiteBrush}"
                           Click="OnRepoClick">github.com/estevanhernandez-stack-ed/ROROROblox</Hyperlink>
            </TextBlock>
            <TextBlock FontSize="11" Margin="0,0,0,4">
                <Hyperlink x:Name="IssuesLink" Foreground="{StaticResource WhiteBrush}"
                           Click="OnIssuesClick">Report an issue</Hyperlink>
            </TextBlock>
            <TextBlock FontSize="11">
                <Hyperlink x:Name="LicenseLink" Foreground="{StaticResource WhiteBrush}"
                           Click="OnLicenseClick">Open log folder</Hyperlink>
            </TextBlock>

            <TextBlock Margin="0,16,0,0" FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap">
                Cookies are encrypted with Windows DPAPI per user. They never leave this machine.
                A copy of accounts.dat moved to another PC will not decrypt.
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Padding="20,8"
                    Background="{StaticResource CyanBrush}"
                    Foreground="{StaticResource NavyBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
