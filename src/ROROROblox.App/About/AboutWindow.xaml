<Window x:Class="ROROROblox.App.About.AboutWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About RoRoRo"
        Height="460" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="CyanBrightBrush" Color="#5CE6FF" />
        <SolidColorBrush x:Key="CyanDimBrush" Color="#0FA8C9" />
        <SolidColorBrush x:Key="CyanShadowBrush" Color="#0A7A92" />
        <SolidColorBrush x:Key="MagentaDimBrush" Color="#C21F6C" />
        <SolidColorBrush x:Key="MagentaShadowBrush" Color="#8A154C" />
        <SolidColorBrush x:Key="NavySoftBrush" Color="#192E44" />
    </Window.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Hero: inline iso voxel stack + wordmark + version + tagline + Easter-egg slot -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <!-- Direction C iso voxel stack (Canvas, 64x64). Painter's order: bottom -> middle -> top. -->
            <Canvas Width="64" Height="64" Margin="0,0,18,0" Background="{StaticResource NavySoftBrush}">
                <!-- Bottom block (cyan) -->
                <Polygon Fill="{DynamicResource CyanBrush}"
                         Points="16,36.5 32,30.5 48,36.5 32,42.5" />
                <Polygon Fill="{StaticResource CyanShadowBrush}"
                         Points="16,36.5 32,42.5 32,51.5 16,45.5" />
                <Polygon Fill="{StaticResource CyanDimBrush}"
                         Points="32,42.5 48,36.5 48,45.5 32,51.5" />
                <!-- Middle block (magenta) -->
                <Polygon Fill="{DynamicResource MagentaBrush}"
                         Points="16,27.5 32,21.5 48,27.5 32,33.5" />
                <Polygon Fill="{StaticResource MagentaShadowBrush}"
                         Points="16,27.5 32,33.5 32,42.5 16,36.5" />
                <Polygon Fill="{StaticResource MagentaDimBrush}"
                         Points="32,33.5 48,27.5 48,36.5 32,42.5" />
                <!-- Top block (cyan-bright) -->
                <Polygon Fill="{StaticResource CyanBrightBrush}"
                         Points="16,18.5 32,12.5 48,18.5 32,24.5" />
                <Polygon Fill="{StaticResource CyanShadowBrush}"
                         Points="16,18.5 32,24.5 32,33.5 16,27.5" />
                <Polygon Fill="{DynamicResource CyanBrush}"
                         Points="32,24.5 48,18.5 48,27.5 32,33.5" />
            </Canvas>

            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="RoRoRo"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource CyanBrush}" />
                    <TextBlock Text=" / "
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource MagentaBrush}" />
                    <TextBlock x:Name="VersionText"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource WhiteBrush}"
                               Cursor="Hand"
                               ToolTip="Version"
                               MouseLeftButtonDown="OnVersionClicked" />
                </StackPanel>
                <TextBlock Text="Multi-launcher for Windows."
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource CyanBrush}"
                           Margin="0,4,0,0" />
                <TextBlock Text="A 626 Labs product"
                           FontSize="10"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Margin="0,2,0,0" />
                <TextBlock x:Name="EasterEggText"
                           Text="Koii 4 eva"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource MagentaBrush}"
                           Margin="0,8,0,0"
                           Visibility="Collapsed"
                           Opacity="0">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#F22F89" BlurRadius="14" ShadowDepth="0" Opacity="0.85" />
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,24,0,0" Padding="16,14"
                Background="#15263A" CornerRadius="8">
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource WhiteBrush}">
                Run multiple Roblox clients side by side, signed in as different saved accounts.
                Holds the Roblox singleton mutex so subsequent clients don't fight for it; uses
                Roblox's documented authentication-ticket flow for per-account launches. Clean
                reimplementation; not a fork.
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="Links" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource CyanBrush}" Margin="0,0,0,6" />
            <TextBlock FontSize="11" Margin="0,0,0,4">
                <Hyperlink x:Name="RepoLink" Foreground="{DynamicResource WhiteBrush}"
                           Click="OnRepoClick">github.com/estevanhernandez-stack-ed/ROROROblox</Hyperlink>
            </TextBlock>
            <TextBlock FontSize="11" Margin="0,0,0,4">
                <Hyperlink x:Name="IssuesLink" Foreground="{DynamicResource WhiteBrush}"
                           Click="OnIssuesClick">Report an issue</Hyperlink>
            </TextBlock>
            <TextBlock FontSize="11">
                <Hyperlink x:Name="LicenseLink" Foreground="{DynamicResource WhiteBrush}"
                           Click="OnLicenseClick">Open log folder</Hyperlink>
            </TextBlock>

            <TextBlock Margin="0,16,0,0" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"
                       TextWrapping="Wrap">
                Cookies are encrypted with Windows DPAPI per user. They never leave this machine.
                A copy of accounts.dat moved to another PC will not decrypt.
            </TextBlock>
            <TextBlock Margin="0,8,0,0" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"
                       TextWrapping="Wrap">
                "Roblox" is a trademark of Roblox Corporation. RoRoRo is not affiliated with,
                endorsed by, or sponsored by Roblox Corporation.
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Padding="20,8"
                    Background="{DynamicResource CyanBrush}"
                    Foreground="{DynamicResource NavyBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
