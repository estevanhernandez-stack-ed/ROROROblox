<Window x:Class="ROROROblox.App.About.WelcomeWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to ROROROblox"
        Height="500" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1F31"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="DividerBrush" Color="#1F3149" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9AA8B8" />
        <SolidColorBrush x:Key="CyanBrush" Color="#17D4FA" />
        <SolidColorBrush x:Key="MagentaBrush" Color="#F22F89" />
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="NavyBrush" Color="#0F1F31" />
        <SolidColorBrush x:Key="RowBgBrush" Color="#15263A" />

        <Style x:Key="StepStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource RowBgBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="StepNumberStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CyanBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Welcome to "
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource WhiteBrush}" />
                <TextBlock Text="ROROROblox"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource CyanBrush}" />
            </StackPanel>
            <TextBlock Text="Run multiple Roblox clients side by side. Three steps and you're set."
                       FontSize="12"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,22,0,0">
            <Border Style="{StaticResource StepStyle}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepNumberStyle}">
                        <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" FontWeight="Bold" Foreground="{StaticResource NavyBrush}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Click + Add Account."
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource WhiteBrush}" />
                        <TextBlock Text="Sign in to roblox.com in the popup. We capture the cookie, encrypt it, and never see your password."
                                   FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StepStyle}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepNumberStyle}">
                        <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" FontWeight="Bold" Foreground="{StaticResource NavyBrush}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Open Games and add the place you launch into."
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource WhiteBrush}" />
                        <TextBlock Text="Search by name or paste a roblox.com/games/&lt;id&gt; URL. The default game is what Launch As uses."
                                   FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StepStyle}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepNumberStyle}">
                        <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" FontWeight="Bold" Foreground="{StaticResource NavyBrush}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Click Launch As. Or Launch All for every alt at once."
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource WhiteBrush}" />
                        <TextBlock Text="Multi-Instance is on by default — Roblox windows open side by side without fighting each other for the singleton."
                                   FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Margin="0,12,0,0" FontSize="11"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap">
                Closing the window minimizes to the tray. Right-click the tray icon to fully Quit
                or toggle Multi-Instance. The Diagnostics button in the header shows what the app
                sees if anything looks off.
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Got it" Padding="22,8"
                    Background="{StaticResource CyanBrush}"
                    Foreground="{StaticResource NavyBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
