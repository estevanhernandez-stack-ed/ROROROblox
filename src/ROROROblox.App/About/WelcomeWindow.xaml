<Window x:Class="ROROROblox.App.About.WelcomeWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to RORORO"
        Height="760" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BgBrush}"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Window.Resources>
        <Style x:Key="StepStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource RowBgBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="StepNumberStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CyanBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Welcome to "
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource WhiteBrush}" />
                <TextBlock Text="RORORO"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource CyanBrush}" />
            </StackPanel>
            <TextBlock Text="Run multiple Roblox clients side by side. Three steps and you're set."
                       FontSize="12"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,22,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <Border Style="{StaticResource StepStyle}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepNumberStyle}">
                        <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" FontWeight="Bold" Foreground="{DynamicResource NavyBrush}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Click + Add Account."
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WhiteBrush}" />
                        <TextBlock Text="Sign in to roblox.com in the popup. We capture the cookie, encrypt it, and never see your password."
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StepStyle}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepNumberStyle}">
                        <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" FontWeight="Bold" Foreground="{DynamicResource NavyBrush}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Open Games and add the place you launch into."
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WhiteBrush}" />
                        <TextBlock Text="Search by name or paste a roblox.com/games/&lt;id&gt; URL. The default game is what Launch As uses."
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StepStyle}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepNumberStyle}">
                        <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" FontWeight="Bold" Foreground="{DynamicResource NavyBrush}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Click Launch As. Or Launch All for every alt at once."
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WhiteBrush}" />
                        <TextBlock Text="Multi-Instance is on by default — Roblox windows open side by side without fighting each other for the singleton."
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource RowBgBrush}"
                    CornerRadius="8" Padding="14,10"
                    Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Quick tips for the row controls"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource CyanBrush}"
                               Margin="0,0,0,6" />
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,3">
                        <Run FontWeight="SemiBold" Foreground="{DynamicResource WhiteBrush}" Text="&#x2630;" />
                        <Run Text=" on the left of a row — drag to reorder." />
                    </TextBlock>
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,3">
                        <Run FontWeight="SemiBold" Foreground="{DynamicResource MagentaBrush}" Text="&#x2605;" />
                        <Run Text=" star next to a row's actions — mark that account as your main (one at a time). The main launches on tray double-click and is the default for compact mode." />
                    </TextBlock>
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,3">
                        <Run Text="The colored swatch next to the star — pick a per-account color. The avatar ring + Roblox window title bar pick it up so you can tell windows apart." />
                    </TextBlock>
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,3">
                        <Run Text="The dot labeled " />
                        <Run FontWeight="SemiBold" Foreground="{DynamicResource WhiteBrush}" Text="In batches" />
                        <Run Text=" / " />
                        <Run FontWeight="SemiBold" Foreground="{DynamicResource WhiteBrush}" Text="Skipped" />
                        <Run Text=" — toggles whether this account joins Launch multiple / Private server runs. Persists across restarts." />
                    </TextBlock>
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,3">
                        <Run FontWeight="SemiBold" Foreground="{DynamicResource WhiteBrush}" Text="Follow:" />
                        <Run Text=" chips below an account — click one of your other accounts to launch THIS one into THAT account's current Roblox server." />
                    </TextBlock>
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,3">
                        <Run FontWeight="SemiBold" Foreground="{DynamicResource WhiteBrush}" Text="Compact" />
                        <Run Text=" button at the bottom-left — collapses to a tiny strip showing only running accounts. Great for parking it on a second monitor while you play." />
                    </TextBlock>
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0">
                        Closing X minimizes to tray; right-click the tray icon for Preferences, History,
                        Diagnostics, or Quit.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Got it" Padding="22,8"
                    Background="{DynamicResource CyanBrush}"
                    Foreground="{DynamicResource NavyBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
