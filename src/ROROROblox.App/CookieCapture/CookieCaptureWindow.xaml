<Window x:Class="ROROROblox.App.CookieCapture.CookieCaptureWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Add Roblox Account -- log in"
        Height="700" Width="1024"
        WindowStartupLocation="CenterScreen"
        Background="#0F1F31"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F1F31" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Add Roblox Account"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#17D4FA" />
                <TextBlock FontSize="11"
                           Foreground="#FFFFFF"
                           Opacity="0.9"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap">
                    <Run Text="Your password goes only to " />
                    <Run Text="roblox.com" FontWeight="Bold" />
                    <Run Text=" over HTTPS, inside this embedded browser. ROROROblox never sees it." />
                </TextBlock>
                <TextBlock FontSize="11"
                           Foreground="#FFFFFF"
                           Opacity="0.7"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap">
                    <Run Text="We capture only the session cookie that Roblox sets after a successful login, then encrypt it on disk via Windows DPAPI tied to your user." />
                </TextBlock>
            </StackPanel>
        </Border>

        <wv:WebView2 x:Name="WebView" Grid.Row="1" />
    </Grid>
</Window>
