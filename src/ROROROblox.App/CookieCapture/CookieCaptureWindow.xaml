<Window x:Class="ROROROblox.App.CookieCapture.CookieCaptureWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Add Roblox Account -- log in"
        Height="700" Width="1024"
        WindowStartupLocation="CenterScreen"
        Background="#0F1F31"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F1F31" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Add Roblox Account"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#17D4FA" />
                <TextBlock FontSize="11"
                           Foreground="#FFFFFF"
                           Opacity="0.9"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap">
                    <Run Text="Your password goes only to " />
                    <Run Text="roblox.com" FontWeight="Bold" />
                    <Run Text=" over HTTPS, inside this embedded browser. RoRoRo never sees it." />
                </TextBlock>
                <TextBlock FontSize="11"
                           Foreground="#FFFFFF"
                           Opacity="0.7"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap">
                    <Run Text="We capture only the session cookie that Roblox sets after a successful login, then encrypt it on disk via Windows DPAPI tied to your user." />
                </TextBlock>
                <Border Margin="0,8,0,0" Padding="10,8"
                        Background="#15263A" CornerRadius="4">
                    <StackPanel>
                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                   Foreground="#5CE6FF">
                            <Run Text="If the page is blank, click Reload (F5)." />
                        </TextBlock>
                        <TextBlock FontSize="11"
                                   Foreground="#FFFFFF"
                                   Opacity="0.85"
                                   Margin="0,2,0,0"
                                   TextWrapping="Wrap">
                            <Run Text="The embedded browser sometimes loads slowly on first open. If Roblox asks for two-factor verification, that's normal — verify here and your saved login keeps working." />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <wv:WebView2 x:Name="WebView" />

            <!-- Loading overlay; shown until the first NavigationCompleted fires successfully.
                 Covers the slow CoreWebView2Environment.CreateAsync + EnsureCoreWebView2Async
                 + first Navigate pre-render window. Hidden in code-behind once roblox.com paints. -->
            <Border x:Name="LoadingOverlay"
                    Background="#0F1F31">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Loading roblox.com..."
                               Foreground="#17D4FA"
                               FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12" />
                    <ProgressBar IsIndeterminate="True"
                                 Width="200" Height="4"
                                 Foreground="#17D4FA"
                                 Background="#15263A"
                                 BorderThickness="0" />
                    <TextBlock Text="First open can take a few seconds on a fresh WebView2 install."
                               Foreground="#FFFFFF"
                               Opacity="0.65"
                               FontSize="11"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="300" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
