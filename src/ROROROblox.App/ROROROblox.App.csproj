<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\ROROROblox.Core\ROROROblox.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="2.0.1" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="10.0.7" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3912.50" />
    <PackageReference Include="Microsoft.Windows.CsWin32" Version="0.3.275">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Serilog" Version="4.2.0" />
    <PackageReference Include="Serilog.Extensions.Logging" Version="9.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.0.0" />
    <PackageReference Include="Velopack" Version="0.0.1298" />
    <PackageReference Include="WPF-UI" Version="4.3.0" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <!-- Custom entry point so VelopackApp.Build().Run() executes before WPF starts.
         Replaces the auto-generated Main from App.xaml. -->
    <StartupObject>ROROROblox.App.Program</StartupObject>
    <!-- Assembly version surfaces in the About box via Assembly.GetName().Version.
         Keep in sync with <Identity Version> in Package.appxmanifest. The script
         scripts/finalize-store-build.ps1 patches both atomically on every release. -->
    <Version>1.1.2.0</Version>
  </PropertyGroup>

  <!-- Tray icons: Direction C iso voxel stack on a navy disk with state-coloured ring.
       Generated by scripts/generate-tray-icons.ps1 (programmatic, no external image source).
       The *-titlebar.png variants are 64x64 standalone PNGs the WPF window title bar uses
       directly; ICOs cover the system tray (where multi-size ICO is required). Title bar
       gets PNG to avoid the 16x16 ICO embed's flat-bottom rendering at 18px display. -->
  <ItemGroup>
    <Resource Include="Tray\Resources\tray-on.ico" />
    <Resource Include="Tray\Resources\tray-off.ico" />
    <Resource Include="Tray\Resources\tray-error.ico" />
    <Resource Include="Tray\Resources\tray-on-titlebar.png" />
    <Resource Include="Tray\Resources\tray-off-titlebar.png" />
    <Resource Include="Tray\Resources\tray-error-titlebar.png" />
  </ItemGroup>

  <!-- Embed the source-of-truth agent prompt so the in-app theme builder reads the same
       text users see in docs/. ../../docs reaches up to repo root. The LogicalName is what
       Assembly.GetManifestResourceStream() looks up. -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\docs\themes\AGENT_PROMPT.md"
                      LogicalName="ROROROblox.App.Themes.AGENT_PROMPT.md" />
  </ItemGroup>

</Project>
