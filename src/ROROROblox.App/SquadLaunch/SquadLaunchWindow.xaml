<Window x:Class="ROROROblox.App.SquadLaunch.SquadLaunchWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Squad Launch"
        Height="600" Width="640"
        MinHeight="480" MinWidth="540"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Window.Resources>
    </Window.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Squad Launch"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource CyanBrush}" />
                <TextBlock Text=" / "
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource MagentaBrush}" />
                <TextBlock Text="every account, one server"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource WhiteBrush}" />
            </StackPanel>
            <TextBlock Text="Send every active account into the same Roblox private server. Each cookie auths separately; Roblox just needs the share link to know which server."
                       FontSize="11"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,20,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SavedServersList" />
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource RowBgBrush}" CornerRadius="8" Padding="14" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="Add by URL" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource CyanBrush}" Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap" FontSize="10"
                           Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,8">
                    Paste a private server share link — looks like
                    <Run FontFamily="Consolas">https://www.roblox.com/games/&lt;id&gt;/&lt;name&gt;?privateServerLinkCode=&lt;code&gt;</Run>
                </TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UrlInput" Grid.Column="0"
                             Padding="8,6" FontSize="11"
                             Background="{DynamicResource NavyBrush}"
                             Foreground="{DynamicResource WhiteBrush}"
                             BorderBrush="{DynamicResource DividerBrush}"
                             BorderThickness="1"
                             VerticalContentAlignment="Center" />
                    <Button x:Name="AddButton" Grid.Column="1"
                            Content="Add and launch all"
                            Padding="14,6" Margin="8,0,0,0"
                            Background="{DynamicResource MagentaBrush}"
                            Foreground="{DynamicResource WhiteBrush}"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="OnAddAndLaunchClick" />
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" x:Name="EligibilityText"
                   FontSize="11"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap" />

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusText"
                       FontSize="11"
                       Foreground="{DynamicResource MutedTextBrush}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
            <Button Grid.Column="1" Content="Close" Padding="14,8"
                    Background="{DynamicResource NavyBrush}"
                    Foreground="{DynamicResource WhiteBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="1"
                    IsCancel="True"
                    Click="OnCloseClick" />
        </Grid>
    </Grid>
</Window>
