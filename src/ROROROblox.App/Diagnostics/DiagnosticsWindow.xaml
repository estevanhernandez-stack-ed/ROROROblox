<Window x:Class="ROROROblox.App.Diagnostics.DiagnosticsWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ROROROblox -- Diagnostics"
        Height="560" Width="640"
        MinHeight="420" MinWidth="540"
        WindowStartupLocation="CenterOwner"
        Background="#0F1F31"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="DividerBrush" Color="#1F3149" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9AA8B8" />
        <SolidColorBrush x:Key="CyanBrush" Color="#17D4FA" />
        <SolidColorBrush x:Key="MagentaBrush" Color="#F22F89" />
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="NavyBrush" Color="#0F1F31" />
        <SolidColorBrush x:Key="RowBgBrush" Color="#15263A" />
    </Window.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Diagnostics"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource CyanBrush}" />
                <TextBlock Text=" / "
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource MagentaBrush}" />
                <TextBlock Text="System health"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource WhiteBrush}" />
            </StackPanel>
            <TextBlock Text="Snapshot of what ROROROblox sees right now. Save the bundle when filing a bug — log files redact secrets."
                       FontSize="11"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,20,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="DetailsList" />
        </ScrollViewer>

        <TextBlock Grid.Row="2" x:Name="StatusText"
                   FontSize="11"
                   Foreground="{StaticResource MutedTextBrush}"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OpenLogFolderButton" Content="Open log folder"
                    Padding="12,8" Margin="0,0,8,0"
                    Background="{StaticResource NavyBrush}"
                    Foreground="{StaticResource WhiteBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    Click="OnOpenLogFolderClick" />
            <Button x:Name="OpenDataFolderButton" Content="Open data folder"
                    Padding="12,8" Margin="0,0,8,0"
                    Background="{StaticResource NavyBrush}"
                    Foreground="{StaticResource WhiteBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    Click="OnOpenDataFolderClick" />
            <Button x:Name="SaveBundleButton" Content="Save support bundle (.zip)"
                    Padding="14,8" Margin="0,0,8,0"
                    Background="{StaticResource CyanBrush}"
                    Foreground="{StaticResource NavyBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="OnSaveBundleClick"
                    ToolTip="Bundle the latest log files + this snapshot into a zip you can attach to a Discord report. Cookies are never logged; the bundle contains no secrets." />
            <Button Content="Close" Padding="14,8"
                    Background="{StaticResource NavyBrush}"
                    Foreground="{StaticResource WhiteBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    IsCancel="True"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
