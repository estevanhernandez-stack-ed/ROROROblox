<Window x:Class="ROROROblox.App.History.SessionHistoryWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ROROROblox -- History"
        Height="600" Width="700"
        MinHeight="420" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Window.Resources>
    </Window.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="History"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource CyanBrush}" />
                <TextBlock Text=" / "
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource MagentaBrush}" />
                <TextBlock Text="Recent sessions"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource WhiteBrush}" />
            </StackPanel>
            <TextBlock Text="What each account has launched into recently. Newest first; the last 100 sessions are kept."
                       FontSize="11"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,20,0,0"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="HistoryList" Margin="8" />
                </ScrollViewer>
                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="No launches yet."
                               FontSize="13"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Click Launch As on any account and you'll see entries here."
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               Opacity="0.7" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ClearButton" Content="Clear history"
                    Padding="12,8" Margin="0,0,8,0"
                    Background="{DynamicResource NavyBrush}"
                    Foreground="{DynamicResource MutedTextBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="1"
                    Click="OnClearClick" />
            <Button Content="Close" Padding="22,8"
                    Background="{DynamicResource CyanBrush}"
                    Foreground="{DynamicResource NavyBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
