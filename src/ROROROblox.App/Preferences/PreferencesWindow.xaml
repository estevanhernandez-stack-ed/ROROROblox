<Window x:Class="ROROROblox.App.Preferences.PreferencesWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RORORO -- Preferences"
        Height="780" Width="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Preferences"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource CyanBrush}" />
                <TextBlock Text=" / "
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource MagentaBrush}" />
                <TextBlock Text="Startup"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource WhiteBrush}" />
            </StackPanel>
            <TextBlock Text="How RORORO behaves when Windows starts up."
                       FontSize="11"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,24,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{DynamicResource RowBgBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <CheckBox x:Name="RunOnLoginToggle"
                                  Foreground="{DynamicResource WhiteBrush}"
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Click="OnRunOnLoginToggle">
                            <TextBlock Text="Start RORORO when Windows starts." />
                        </CheckBox>
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="22,4,0,0"
                                   Text="Adds a value under HKCU Run. Removes it when unchecked." />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource RowBgBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <CheckBox x:Name="LaunchMainToggle"
                                  Foreground="{DynamicResource WhiteBrush}"
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Click="OnLaunchMainToggle">
                            <TextBlock Text="Launch my main account when RORORO starts." />
                        </CheckBox>
                        <TextBlock x:Name="LaunchMainHint"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="22,4,0,0"
                                   Text="Pair with the toggle above for a one-step boot-to-Roblox setup. Pick a main account in the row list (the &#x2606; star) first." />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource RowBgBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Theme"
                                   Foreground="{DynamicResource WhiteBrush}"
                                   FontSize="13" FontWeight="SemiBold" />
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,8"
                                   Text="Pick a built-in or drop your own JSON in the themes folder. The main window updates immediately; secondary dialogs (this one, Diagnostics, About) adopt the theme on next open." />
                        <ComboBox x:Name="ThemePicker"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="OnThemeChanged"
                                  Background="{DynamicResource NavyBrush}"
                                  Foreground="{DynamicResource WhiteBrush}"
                                  BorderBrush="{DynamicResource DividerBrush}"
                                  Padding="8,6"
                                  FontSize="12" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="BuildThemeButton"
                                    Content="+ Build a theme..."
                                    HorizontalAlignment="Left"
                                    Padding="10,5" Margin="0,0,8,0"
                                    Background="{DynamicResource MagentaBrush}"
                                    Foreground="{DynamicResource WhiteBrush}"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    FontSize="11"
                                    Click="OnBuildThemeClick"
                                    ToolTip="Open the theme builder. Copy an AI prompt, paste the result back, save." />
                            <Button x:Name="OpenThemesFolderButton"
                                    Content="Open themes folder"
                                    HorizontalAlignment="Left"
                                    Padding="10,5"
                                    Background="{DynamicResource NavyBrush}"
                                    Foreground="{DynamicResource MutedTextBrush}"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="1"
                                    FontSize="11"
                                    Click="OnOpenThemesFolderClick"
                                    ToolTip="Drop a *.json file in here to make it appear in the picker after restart." />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- v1.2 Discord clan-coordination — folded in here per CHECKPOINT-1.5 feedback.
                     Settings live with the rest of the prefs, not behind a separate tray entry. -->
                <Border Background="{DynamicResource RowBgBrush}" CornerRadius="8" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Discord integration"
                                   Foreground="{DynamicResource WhiteBrush}"
                                   FontSize="13" FontWeight="SemiBold" />
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,8"
                                   Text="Show RORORO in your Discord status, and optionally post clan-channel updates." />

                        <CheckBox x:Name="RichPresenceToggle"
                                  Foreground="{DynamicResource WhiteBrush}"
                                  FontSize="12"
                                  FontWeight="SemiBold"
                                  Margin="0,4,0,0"
                                  Click="OnRichPresenceToggle">
                            <TextBlock Text="Show RORORO in your Discord status." />
                        </CheckBox>
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="22,2,0,8"
                                   Text="Your profile shows RORORO is open + how many alts are active. No usernames." />

                        <Border Background="{DynamicResource DividerBrush}" Height="1" Margin="0,4,0,8" />

                        <TextBlock Text="Clan channel webhook (optional)"
                                   Foreground="{DynamicResource WhiteBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="0,0,0,4" />
                        <TextBox x:Name="WebhookUrlBox"
                                 Background="{DynamicResource NavyBrush}"
                                 Foreground="{DynamicResource WhiteBrush}"
                                 BorderBrush="{DynamicResource DividerBrush}"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 FontSize="11"
                                 FontFamily="Consolas"
                                 TextChanged="OnWebhookUrlChanged"
                                 LostFocus="OnWebhookUrlLostFocus" />
                        <TextBlock x:Name="WebhookUrlHint"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,8"
                                   Text="Paste a webhook URL from your clan's Discord channel admin." />

                        <CheckBox x:Name="OnLaunchToggle"
                                  Foreground="{DynamicResource WhiteBrush}"
                                  FontSize="12"
                                  Margin="0,2,0,2"
                                  Click="OnDiscordEventToggle">
                            <TextBlock Text="Post when I start ROROROblox" />
                        </CheckBox>
                        <CheckBox x:Name="OnPrivateServerJoinToggle"
                                  Foreground="{DynamicResource WhiteBrush}"
                                  FontSize="12"
                                  Margin="0,2,0,2"
                                  Click="OnDiscordEventToggle">
                            <TextBlock Text="Post when I join a private server" />
                        </CheckBox>
                        <CheckBox x:Name="OnNAccountsToggle"
                                  Foreground="{DynamicResource WhiteBrush}"
                                  FontSize="12"
                                  Margin="0,2,0,2"
                                  Click="OnDiscordEventToggle">
                            <TextBlock Text="Post when I have 4+ accounts running at once" />
                        </CheckBox>

                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   Text="All Discord settings default OFF. Each clanmate opts in separately." />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Close" Padding="22,8"
                    Background="{DynamicResource CyanBrush}"
                    Foreground="{DynamicResource NavyBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
