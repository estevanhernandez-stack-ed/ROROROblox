<Window x:Class="ROROROblox.App.Modals.RobloxAlreadyRunningWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roblox is already running"
        Height="440" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico"
        Background="{DynamicResource BgBrush}">
    <!-- BLOCKED startup modal. Pre-empts MainWindow when RobloxPlayerBeta.exe is already holding
         the multi-instance mutex at app launch — often a tray-resident, windowless Roblox process
         (spec §5/§6). Offers in-place recovery (Retry / Close Roblox for me) before falling back
         to Quit RoRoRo; never tells the user to restart RoRoRo itself. WindowStartupLocation is
         CenterScreen (not CenterOwner) because there is no owner at this point in startup.

         Retry is the primary and the Enter default — see the button block below for why the
         destructive action deliberately is not. -->
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Heading -->
        <TextBlock Grid.Row="0" Text="Roblox is already running"
                   FontSize="18" FontWeight="Bold" Foreground="#17D4FA" />

        <!-- Body: the tray-residence explanation -->
        <TextBlock Grid.Row="1"
                   Text="RoRoRo needs the multi-instance lock, but Roblox is holding it — it may be running with no window at all, hidden in your system tray."
                   TextWrapping="Wrap" FontSize="12" Foreground="#FFFFFF" Opacity="0.85"
                   Margin="0,12,0,0" />

        <!-- Steps: how to quit from the tray -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,12,0,0">
            <TextBlock FontSize="12" Margin="0,2,0,0">
                <Run Text="1." Foreground="#F22F89" FontWeight="Bold" />
                <Run Text=" Click the ^ near the clock (bottom-right)" Foreground="#FFFFFF" />
            </TextBlock>
            <TextBlock FontSize="12" Margin="0,2,0,0">
                <Run Text="2." Foreground="#F22F89" FontWeight="Bold" />
                <Run Text=" Right-click the Roblox icon" Foreground="#FFFFFF" />
            </TextBlock>
            <TextBlock FontSize="12" Margin="0,2,0,0">
                <Run Text="3." Foreground="#F22F89" FontWeight="Bold" />
                <Run Text=" Choose Quit Roblox — then hit Retry" Foreground="#FFFFFF" />
            </TextBlock>
        </StackPanel>

        <!-- Start-with-Windows note -->
        <TextBlock Grid.Row="3"
                   Text="Roblox can start itself with Windows. You can turn that off in Roblox's tray settings — but you don't have to; RoRoRo will catch it here either way."
                   TextWrapping="Wrap" FontSize="11" Foreground="#8A93A0" Margin="0,12,0,0" />

        <!-- Bottom-of-body notes: still-locked tick (hidden until a failed retry) + the
             Start-anyway explanation -->
        <StackPanel Grid.Row="4" VerticalAlignment="Bottom">
            <TextBlock x:Name="StillLockedTick"
                       FontFamily="JetBrains Mono, Cascadia Mono, Consolas" FontSize="10"
                       Foreground="#F1B232" Margin="0,12,0,0" Visibility="Collapsed" />
            <TextBlock Text="Already have another copy of RoRoRo or a compatible tool holding the lock? Start anyway — multi-instance keeps working, and RoRoRo will show a banner while it doesn't hold the lock."
                       TextWrapping="Wrap" FontSize="11" Foreground="#8A93A0" Margin="0,12,0,0" />
        </StackPanel>

        <!-- Four actions.

             Retry is the primary AND the Enter-key default, matching step 3 above ("Quit Roblox —
             then hit Retry"). It is non-destructive: it re-acquires in place, and on failure just
             reveals the still-locked tick.

             "Close Roblox for me" force-closes the user's running Roblox clients, losing any
             unsaved in-game progress. It must NOT be IsDefault: this modal appears at startup, and
             a reflexive Enter on a dialog you didn't expect should never destroy state. It stays
             clearly available, just not on the Enter key. Guarded by ModalDefaultButtonSafetyTests. -->
        <StackPanel Grid.Row="5" x:Name="ActionButtons" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Quit RoRoRo" Padding="16,8" IsCancel="True"
                    Background="#22314A" Foreground="#FFFFFF" BorderThickness="0"
                    Margin="0,0,8,0" Click="OnQuitClick" />
            <Button Content="Start anyway" Padding="16,8"
                    Background="#22314A" Foreground="#FFFFFF" BorderThickness="0"
                    Margin="0,0,8,0" Click="OnStartAnywayClick" />
            <Button Content="Close Roblox for me" Padding="16,8"
                    Background="#22314A" Foreground="#FFFFFF" BorderThickness="0"
                    Margin="0,0,8,0" Click="OnCloseForMeClick" />
            <Button Content="Retry" Padding="16,8" IsDefault="True"
                    Background="#17D4FA" Foreground="#0F1F31" BorderThickness="0"
                    FontWeight="Bold" Click="OnRetryClick" />
        </StackPanel>
    </Grid>
</Window>
