<Window x:Class="ROROROblox.App.Modals.RobloxNotInstalledWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roblox needed"
        Height="320" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Roblox doesn't appear to be installed"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#F22F89" />

        <TextBlock Grid.Row="1"
                   Text="RoRoRo launches Roblox via the standard roblox-player: handler. We can't find that handler on this PC, which usually means Roblox isn't installed yet."
                   TextWrapping="Wrap"
                   FontSize="12"
                   Foreground="#FFFFFF"
                   Opacity="0.85"
                   Margin="0,12,0,0" />

        <TextBlock Grid.Row="2"
                   Text="If you use Bloxstrap, make sure it's set as the default Roblox launcher in its settings — Bloxstrap should also handle our launches."
                   TextWrapping="Wrap"
                   FontSize="11"
                   Foreground="#FFFFFF"
                   Opacity="0.7"
                   Margin="0,8,0,0" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="I have Bloxstrap" Padding="16,8" Margin="0,0,8,0"
                    Background="{DynamicResource BgBrush}" Foreground="#FFFFFF" BorderBrush="#5A6982" BorderThickness="1"
                    Click="OnBloxstrapClick" />
            <Button Content="Download Roblox" Padding="16,8" IsDefault="True"
                    Background="#17D4FA" Foreground="#0F1F31" BorderThickness="0"
                    FontWeight="Bold"
                    Click="OnDownloadClick" />
        </StackPanel>
    </Grid>
</Window>
