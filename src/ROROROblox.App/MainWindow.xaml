<ui:FluentWindow x:Class="ROROROblox.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:ROROROblox.App.ViewModels"
                 Title="ROROROblox"
                 Height="600" Width="780"
                 MinHeight="400" MinWidth="640"
                 WindowStartupLocation="CenterScreen"
                 Background="#0F1F31"
                 Icon="/ROROROblox.App;component/Tray/Resources/tray-on.ico"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Default">

    <ui:FluentWindow.Resources>
        <!-- Header divider -->
        <SolidColorBrush x:Key="DividerBrush" Color="#1F3149" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9AA8B8" />
        <SolidColorBrush x:Key="CyanBrush" Color="#17D4FA" />
        <SolidColorBrush x:Key="MagentaBrush" Color="#F22F89" />
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="NavyBrush" Color="#0F1F31" />
        <SolidColorBrush x:Key="RowBgBrush" Color="#15263A" />
        <SolidColorBrush x:Key="RowExpiredBgBrush" Color="#3A2D14" />
        <SolidColorBrush x:Key="RowExpiredAccentBrush" Color="#F1B232" />

        <!-- Account row template -->
        <DataTemplate DataType="{x:Type vm:AccountSummary}">
            <Border Margin="0,0,0,8" Padding="14,10"
                    CornerRadius="8"
                    Background="{StaticResource RowBgBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SessionExpired}" Value="True">
                                <Setter Property="Background" Value="{StaticResource RowExpiredBgBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource RowExpiredAccentBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24"
                            Background="{StaticResource NavyBrush}" ClipToBounds="True"
                            VerticalAlignment="Center">
                        <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill" />
                    </Border>

                    <!-- Name + status -->
                    <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource WhiteBrush}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <!-- Live status dot: green=running, yellow=expired, grey=idle. -->
                            <Ellipse Width="8" Height="8"
                                     Fill="{Binding StatusDot, Converter={StaticResource StatusDotBrushConverter}}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0" />
                            <TextBlock Text="{Binding SecondaryStatusText}"
                                       FontSize="11"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SessionExpired}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource RowExpiredAccentBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Re-authenticate (visible when SessionExpired) -->
                        <Button Content="Re-authenticate"
                                Command="{Binding DataContext.ReauthenticateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="12,6" Margin="0,0,8,0"
                                Background="{StaticResource RowExpiredAccentBrush}"
                                Foreground="{StaticResource NavyBrush}"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Visibility="{Binding SessionExpired, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Friends — opens per-account follow modal. Disabled when expired. -->
                        <Button Content="Friends"
                                Command="{Binding DataContext.OpenFriendFollowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="10,6" Margin="0,0,8,0"
                                Background="{StaticResource NavyBrush}"
                                Foreground="{StaticResource MutedTextBrush}"
                                BorderBrush="{StaticResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11"
                                ToolTip="See this account's friends and follow one into their server (works for public + private)."
                                IsEnabled="{Binding SessionExpired, Converter={StaticResource InverseBoolConverter}}" />

                        <!-- Per-account game picker. Empty-state hint overlays the ComboBox until
                             at least one game is in the library, otherwise it looks broken. -->
                        <Grid Margin="0,0,8,0" MinWidth="200" VerticalAlignment="Center">
                            <ComboBox ItemsSource="{Binding DataContext.AvailableGames, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding SelectedGame}"
                                      DisplayMemberPath="Name"
                                      VerticalAlignment="Center"
                                      ToolTip="Game to launch this account into. Manage games via the header Games button." />
                            <TextBlock Text="Add games with the Games button"
                                       FontSize="11"
                                       FontStyle="Italic"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Opacity="0.85"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       Margin="10,0,30,0"
                                       Visibility="{Binding DataContext.AvailableGames.Count, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ZeroToVisibilityConverter}}" />
                        </Grid>

                        <!-- Launch As (hidden while running — Stop takes its place) -->
                        <Button Content="Launch As"
                                Command="{Binding DataContext.LaunchAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="{StaticResource CyanBrush}"
                                Foreground="{StaticResource NavyBrush}"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                IsEnabled="{Binding IsLaunching, Converter={StaticResource InverseBoolConverter}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Stop (visible while running) -->
                        <Button Content="Stop"
                                Command="{Binding DataContext.StopAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="{StaticResource MagentaBrush}"
                                Foreground="{StaticResource WhiteBrush}"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                ToolTip="Close the Roblox window for this account."
                                Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Remove -->
                        <Button Content="Remove"
                                Command="{Binding DataContext.RemoveAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="10,6"
                                Background="{StaticResource NavyBrush}"
                                Foreground="{StaticResource MutedTextBrush}"
                                BorderBrush="{StaticResource DividerBrush}"
                                BorderThickness="1" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- TitleBar -->
            <RowDefinition Height="Auto" />  <!-- Header -->
            <RowDefinition Height="Auto" />  <!-- StatusBanner -->
            <RowDefinition Height="Auto" />  <!-- Compat banner -->
            <RowDefinition Height="*" />     <!-- Account list -->
            <RowDefinition Height="Auto" />  <!-- Footer -->
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="ROROROblox"
                     ShowMaximize="True"
                     ShowMinimize="True"
                     ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/ROROROblox.App;component/Tray/Resources/tray-on.ico" Width="18" Height="18" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Header -->
        <Border Grid.Row="1" Padding="24,18" Background="{StaticResource NavyBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ROROROblox"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource CyanBrush}" />
                        <TextBlock Text=" / "
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource MagentaBrush}" />
                        <TextBlock Text="Accounts"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource WhiteBrush}" />
                    </StackPanel>
                    <TextBlock Text="Run multiple Roblox clients side by side. Add a saved account, click Launch As to open it."
                               FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="About"
                            Command="{Binding OpenAboutCommand}"
                            Padding="10,8" Margin="0,0,6,0"
                            Background="Transparent"
                            Foreground="{StaticResource MutedTextBrush}"
                            BorderThickness="0"
                            FontSize="11"
                            ToolTip="Version, links, license." />
                    <Button Content="Diagnostics"
                            Command="{Binding OpenDiagnosticsCommand}"
                            Padding="12,8" Margin="0,0,6,0"
                            Background="{StaticResource NavyBrush}"
                            Foreground="{StaticResource MutedTextBrush}"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="1"
                            FontSize="12"
                            ToolTip="System health, Roblox + WebView2 versions, log location." />
                    <Button Content="Games"
                            Command="{Binding OpenSettingsCommand}"
                            Padding="14,8" Margin="0,0,8,0"
                            Background="{StaticResource NavyBrush}"
                            Foreground="{StaticResource MutedTextBrush}"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="1"
                            FontSize="12" />
                    <Button Content="Squad Launch"
                            Command="{Binding OpenSquadLaunchCommand}"
                            Padding="14,8" Margin="0,0,8,0"
                            Background="{StaticResource MagentaBrush}"
                            Foreground="{StaticResource WhiteBrush}"
                            BorderThickness="0"
                            FontSize="12"
                            FontWeight="SemiBold"
                            ToolTip="Send every active account into the same private server. Pet Sim 99 squad use case." />
                    <Button Content="Launch All"
                            Command="{Binding LaunchAllCommand}"
                            Padding="14,8" Margin="0,0,8,0"
                            Background="{StaticResource NavyBrush}"
                            Foreground="{StaticResource MutedTextBrush}"
                            BorderBrush="{StaticResource MagentaBrush}"
                            BorderThickness="1"
                            FontSize="12"
                            FontWeight="SemiBold"
                            ToolTip="Launch every active account into its per-row game, throttled 1.5s apart so the tracker can attach to each client." />
                    <Button Content="+ Add Account"
                            Command="{Binding AddAccountCommand}"
                            Padding="16,8"
                            Background="{StaticResource CyanBrush}"
                            Foreground="{StaticResource NavyBrush}"
                            BorderThickness="0"
                            FontWeight="Bold"
                            FontSize="13" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status banner -->
        <Border Grid.Row="2" Padding="24,8"
                Background="{StaticResource RowBgBrush}"
                Visibility="{Binding StatusBanner, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusBanner}"
                       FontSize="11"
                       Foreground="{StaticResource WhiteBrush}" />
        </Border>

        <!-- Roblox compat banner (drift detection per spec §7.1) -->
        <Border Grid.Row="3" Padding="24,10"
                Background="{StaticResource RowExpiredBgBrush}"
                BorderBrush="{StaticResource RowExpiredAccentBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding RobloxCompatBanner, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding RobloxCompatBanner}"
                       FontSize="11"
                       Foreground="{StaticResource RowExpiredAccentBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Account list -->
        <ScrollViewer Grid.Row="4" Padding="24,16,24,16" VerticalScrollBarVisibility="Auto">
            <Grid>
                <ItemsControl ItemsSource="{Binding Accounts}" />

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding Accounts.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                    <TextBlock Text="No saved accounts yet."
                               FontSize="14"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Click + Add Account to log in to your first Roblox account."
                               FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               Opacity="0.7" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="5" Padding="24,10" Background="{StaticResource NavyBrush}"
                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7"
                             VerticalAlignment="Center" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#4FE08C" />
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LiveProcessCount}" Value="0">
                                        <Setter Property="Fill">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#4A5C70" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding LiveProcessSummary}"
                               FontSize="11"
                               Foreground="{StaticResource WhiteBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="A 626 Labs product. Imagine Something Else."
                           FontSize="10"
                           Foreground="{StaticResource MutedTextBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="Closing the X minimizes to tray. Quit from the tray menu to exit."
                           FontSize="10"
                           Foreground="{StaticResource MutedTextBrush}"
                           Opacity="0.7"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
