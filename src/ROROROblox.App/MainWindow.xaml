<Window x:Class="ROROROblox.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ROROROblox.App.ViewModels"
        Title="ROROROblox"
        Height="600" Width="780"
        MinHeight="400" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="#0F1F31">

    <Window.Resources>
        <!-- Header divider -->
        <SolidColorBrush x:Key="DividerBrush" Color="#1F3149" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9AA8B8" />
        <SolidColorBrush x:Key="CyanBrush" Color="#17D4FA" />
        <SolidColorBrush x:Key="MagentaBrush" Color="#F22F89" />
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="NavyBrush" Color="#0F1F31" />
        <SolidColorBrush x:Key="RowBgBrush" Color="#15263A" />
        <SolidColorBrush x:Key="RowExpiredBgBrush" Color="#3A2D14" />
        <SolidColorBrush x:Key="RowExpiredAccentBrush" Color="#F1B232" />

        <!-- Account row template -->
        <DataTemplate DataType="{x:Type vm:AccountSummary}">
            <Border Margin="0,0,0,8" Padding="14,10"
                    CornerRadius="8"
                    Background="{StaticResource RowBgBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SessionExpired}" Value="True">
                                <Setter Property="Background" Value="{StaticResource RowExpiredBgBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource RowExpiredAccentBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24"
                            Background="{StaticResource NavyBrush}" ClipToBounds="True"
                            VerticalAlignment="Center">
                        <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill" />
                    </Border>

                    <!-- Name + status -->
                    <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource WhiteBrush}" />
                        <TextBlock FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding StatusText}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusText}" Value="">
                                            <Setter Property="Text" Value="Ready" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SessionExpired}" Value="True">
                                            <Setter Property="Text" Value="Session expired" />
                                            <Setter Property="Foreground" Value="{StaticResource RowExpiredAccentBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Re-authenticate (visible when SessionExpired) -->
                        <Button Content="Re-authenticate"
                                Command="{Binding DataContext.ReauthenticateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="12,6" Margin="0,0,8,0"
                                Background="{StaticResource RowExpiredAccentBrush}"
                                Foreground="{StaticResource NavyBrush}"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Visibility="{Binding SessionExpired, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Launch As -->
                        <Button Content="Launch As"
                                Command="{Binding DataContext.LaunchAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="{StaticResource CyanBrush}"
                                Foreground="{StaticResource NavyBrush}"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                IsEnabled="{Binding IsLaunching, Converter={StaticResource InverseBoolConverter}}" />

                        <!-- Remove -->
                        <Button Content="Remove"
                                Command="{Binding DataContext.RemoveAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="10,6"
                                Background="{StaticResource NavyBrush}"
                                Foreground="{StaticResource MutedTextBrush}"
                                BorderBrush="{StaticResource DividerBrush}"
                                BorderThickness="1" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,18" Background="{StaticResource NavyBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ROROROblox"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource CyanBrush}" />
                        <TextBlock Text=" / "
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource MagentaBrush}" />
                        <TextBlock Text="Accounts"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource WhiteBrush}" />
                    </StackPanel>
                    <TextBlock Text="Run multiple Roblox clients side by side. Add a saved account, click Launch As to open it."
                               FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Button Grid.Column="1" Content="+ Add Account"
                        Command="{Binding AddAccountCommand}"
                        Padding="16,8" VerticalAlignment="Center"
                        Background="{StaticResource CyanBrush}"
                        Foreground="{StaticResource NavyBrush}"
                        BorderThickness="0"
                        FontWeight="Bold"
                        FontSize="13" />
            </Grid>
        </Border>

        <!-- Status banner -->
        <Border Grid.Row="1" Padding="24,8"
                Background="{StaticResource RowBgBrush}"
                Visibility="{Binding StatusBanner, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusBanner}"
                       FontSize="11"
                       Foreground="{StaticResource WhiteBrush}" />
        </Border>

        <!-- Account list -->
        <ScrollViewer Grid.Row="2" Padding="24,16,24,16" VerticalScrollBarVisibility="Auto">
            <Grid>
                <ItemsControl ItemsSource="{Binding Accounts}" />

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding Accounts.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                    <TextBlock Text="No saved accounts yet."
                               FontSize="14"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Click + Add Account to log in to your first Roblox account."
                               FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               Opacity="0.7" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Padding="24,10" Background="{StaticResource NavyBrush}"
                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="A 626 Labs product. Imagine Something Else."
                           FontSize="10"
                           Foreground="{StaticResource MutedTextBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="Closing the X minimizes to tray. Quit from the tray menu to exit."
                           FontSize="10"
                           Foreground="{StaticResource MutedTextBrush}"
                           Opacity="0.7"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
