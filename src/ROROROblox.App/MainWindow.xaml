<ui:FluentWindow x:Class="ROROROblox.App.MainWindow"
                 x:ClassModifier="internal"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:ROROROblox.App.ViewModels"
                 Title="RORORO"
                 Height="600" Width="900"
                 MinHeight="400" MinWidth="860"
                 WindowStartupLocation="CenterScreen"
                 AllowDrop="True"
                 Background="{DynamicResource BgBrush}"
                 Icon="/ROROROblox.App;component/Tray/Resources/tray-on-titlebar.png"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Default">

    <ui:FluentWindow.Resources>
        <!-- Themed brushes are now app-level (App.xaml). The ThemeService mutates them in
             place so every {StaticResource} reference re-renders on theme change. -->

        <!-- Compact-mode row template: tighter, single-line, only the live ops info.
             Used by the ItemsControl that renders CompactRows in the compact strip. -->
        <DataTemplate x:Key="CompactAccountTemplate" DataType="{x:Type vm:AccountSummary}">
            <Border Margin="0,0,0,6" Padding="10,8"
                    CornerRadius="6"
                    Background="{DynamicResource RowBgBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                            Background="{DynamicResource NavyBrush}" ClipToBounds="True"
                            VerticalAlignment="Center">
                        <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="10,0,10,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WhiteBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <Border Background="{DynamicResource MagentaBrush}" CornerRadius="2"
                                    Margin="6,2,0,0" Padding="4,1"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsMain, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="MAIN"
                                           FontSize="8" FontWeight="Bold"
                                           Foreground="{DynamicResource WhiteBrush}" />
                            </Border>
                        </StackPanel>
                        <TextBlock FontSize="10" Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding SelectedGame.Name, FallbackValue='(default game)', TargetNullValue='(default game)'}" />
                            <Run Text=" · " />
                            <Run Text="{Binding SecondaryStatusText, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Stop"
                            Command="{Binding DataContext.StopAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Padding="10,4"
                            Background="{DynamicResource MagentaBrush}"
                            Foreground="{DynamicResource WhiteBrush}"
                            BorderThickness="0"
                            FontSize="10"
                            FontWeight="SemiBold"
                            ToolTip="Close the Roblox window for this account."
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Account row template -->
        <DataTemplate DataType="{x:Type vm:AccountSummary}">
            <!-- AllowDrop + Tag={Binding} together with the Window-level drag handlers (in
                 MainWindow.xaml.cs) implement drag-to-reorder: MouseDown on the row's
                 grip-style left edge starts a drag; dropping on another row triggers
                 MainViewModel.MoveAccountAsync. The row no longer carries a MinWidth — the
                 parent Window.MinWidth=860 floors the available width, and the column layout
                 (Auto + * + Auto SharedSizeGroup) settles within that. -->
            <!-- Wrap row in a StackPanel so the cyan insertion-line indicator renders ABOVE
                 the row when this row is the active drop target. Visibility=Collapsed when
                 inactive so the layout doesn't reserve space — the appearance + small layout
                 shift is the visual cue for "drop lands here." -->
            <StackPanel Margin="0,0,0,8">
            <Border Height="3"
                    Margin="0,0,0,4"
                    CornerRadius="2"
                    Background="{DynamicResource CyanBrush}"
                    Visibility="{Binding IsDropTarget, Converter={StaticResource BoolToVisibilityConverter}}" />
            <Border x:Name="AccountRowBorder"
                    Padding="14,10"
                    CornerRadius="8"
                    AllowDrop="True"
                    Tag="{Binding}"
                    DragEnter="OnAccountRowDragEnter"
                    DragLeave="OnAccountRowDragLeave"
                    DragOver="OnAccountRowDragOver"
                    Drop="OnAccountRowDrop"
                    Background="{DynamicResource RowBgBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SessionExpired}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource RowExpiredBgBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource RowExpiredAccentBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <!-- Name column: MinWidth keeps it readable when the action stack on the
                             right grows wide. At default window (780w) this gives ~180px for the
                             name; longer usernames truncate via TextTrimming below. -->
                        <ColumnDefinition Width="*" MinWidth="160" />
                        <!-- Actions column shares its width across every row so the caption-color
                             swatch + star (the first items) line up vertically. Different action
                             stacks (Stop vs Launch As, expired-only Re-authenticate) would
                             otherwise size each row's column independently and shift the swatch. -->
                        <ColumnDefinition Width="Auto" SharedSizeGroup="RowActions" />
                    </Grid.ColumnDefinitions>

                    <!-- Drag-grip — visual cue that the row is reorderable. Press-and-drag the
                         grip to move the row; drop on another row to swap. Tag={Binding} so the
                         Window-level handler knows which AccountSummary started the drag. -->
                    <Border Grid.Column="0" Width="14" Margin="0,0,4,0"
                            Background="Transparent"
                            Cursor="SizeAll"
                            Tag="{Binding}"
                            ToolTip="Drag to reorder this account."
                            PreviewMouseLeftButtonDown="OnAccountGripMouseDown"
                            PreviewMouseMove="OnAccountGripMouseMove">
                        <TextBlock Text="&#x2630;"
                                   FontSize="12"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                    </Border>

                    <!-- Avatar — wrapped in a colored ring driven by the per-account caption color.
                         The ring is what makes the per-account color visible inside the app even
                         when Roblox's window chrome refuses the DWM caption tint. -->
                    <Grid Grid.Column="1" Width="52" Height="52" VerticalAlignment="Center">
                        <Ellipse>
                            <Ellipse.Fill>
                                <MultiBinding Converter="{StaticResource CaptionColorBrushConverter}">
                                    <Binding Path="CaptionColorHex" />
                                    <Binding Path="IsMain" />
                                    <Binding Path="Id" />
                                </MultiBinding>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Border Width="44" Height="44" CornerRadius="22"
                                Background="{DynamicResource NavyBrush}" ClipToBounds="True"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill" />
                        </Border>
                    </Grid>

                    <!-- Name + status -->
                    <StackPanel Grid.Column="2" Margin="14,0,14,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WhiteBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding DisplayName}" />
                            <!-- MAIN pill — magenta, only when this account IsMain. Tells the user
                                 at a glance which row is their default for compact mode + tray double-click. -->
                            <Border Background="{DynamicResource MagentaBrush}" CornerRadius="3"
                                    Margin="10,2,0,0" Padding="6,2"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsMain, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="MAIN"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource WhiteBrush}" />
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <!-- Live status dot: green=running, yellow=expired, grey=idle. -->
                            <Ellipse Width="8" Height="8"
                                     Fill="{Binding StatusDot, Converter={StaticResource StatusDotBrushConverter}}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0" />
                            <TextBlock Text="{Binding SecondaryStatusText}"
                                       FontSize="11"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SessionExpired}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource RowExpiredAccentBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- Selection toggle for batch launches. Filled cyan = included; hollow = skipped.
                                 Defaults to selected; user toggles to exclude an account from Launch multiple
                                 / Private server runs. Persisted to accounts.dat so the choice sticks. -->
                            <ToggleButton Style="{StaticResource SelectionDotStyle}"
                                          IsChecked="{Binding IsSelected}"
                                          Margin="12,0,4,0"
                                          VerticalAlignment="Center"
                                          ToolTip="Include this account in Launch multiple / Private server batches. Click to skip." />
                            <TextBlock FontSize="11"
                                       VerticalAlignment="Center"
                                       ToolTip="Whether this account joins Launch multiple / Private server batch launches. Click the dot to flip.">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="In batches" />
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                                <Setter Property="Text" Value="Skipped" />
                                                <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                                <Setter Property="Opacity" Value="0.65" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Follow strip — "Follow:" label + chips of OTHER accounts. Click a chip to
                             launch THIS row's account into that account's current Roblox server
                             (LaunchTarget.FollowFriend). Self-chip hides via EqualsToCollapseConverter
                             on Id. Whole strip (label + chips) collapses when there's nothing to
                             follow (≤ 1 saved account). -->
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.Accounts.Count, RelativeSource={RelativeSource AncestorType=Window}}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DataContext.Accounts.Count, RelativeSource={RelativeSource AncestorType=Window}}" Value="1">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Follow:"
                                       FontSize="10"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       ToolTip="Click a chip to launch this account into another account's current Roblox server." />
                            <ItemsControl ItemsSource="{Binding DataContext.Accounts, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:AccountSummary}">
                                    <Button Click="OnFollowChipClick"
                                            Tag="{Binding}"
                                            Margin="0,0,6,0"
                                            Padding="6,3"
                                            BorderThickness="1"
                                            Background="{DynamicResource NavyBrush}"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            Cursor="Hand">
                                        <!-- Hide the chip that represents the row's own account so
                                             you can't follow yourself. -->
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Value="Collapsed">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource EqualsToCollapseConverter}">
                                                                <Binding Path="Id" />
                                                                <Binding Path="DataContext.Id" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.ToolTip>
                                            <TextBlock>
                                                <Run Text="Follow " /><Run Text="{Binding DisplayName, Mode=OneWay}" /><Run Text=" into their server" />
                                            </TextBlock>
                                        </Button.ToolTip>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="14" Height="14" CornerRadius="7"
                                                    Background="{DynamicResource NavyBrush}"
                                                    ClipToBounds="True"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,5,0">
                                                <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill" />
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource WhiteBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="80" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </StackPanel>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Title-bar color swatch. Click opens a popup with the 8-palette + Auto +
                             custom hex. The swatch shows whatever color the Roblox window's title
                             bar currently uses (manual override OR auto-derived from Id hash). -->
                        <Border Width="22" Height="14"
                                CornerRadius="3"
                                Margin="0,0,8,0"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                Cursor="Hand"
                                ToolTip="Pick a Roblox window title-bar color for this account."
                                MouseLeftButtonUp="OnCaptionColorSwatchClick"
                                Tag="{Binding}">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource CaptionColorBrushConverter}">
                                    <Binding Path="CaptionColorHex" />
                                    <Binding Path="IsMain" />
                                    <Binding Path="Id" />
                                </MultiBinding>
                            </Border.Background>
                        </Border>

                        <!-- Set / unset main. Magenta filled star = main; outlined grey star = not.
                             Click toggles. Lives leftmost so it groups visually with the MAIN pill on
                             the name line above. -->
                        <Button Command="{Binding DataContext.SetMainCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="6,4" Margin="0,0,8,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.ToolTip>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Set as main account. Drives the compact-mode CTA + tray double-click target." />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMain}" Value="True">
                                                    <Setter Property="Text" Value="This is your main account. Click to unset." />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.ToolTip>
                            <TextBlock FontSize="14" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#x2606;" />
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMain}" Value="True">
                                                <Setter Property="Text" Value="&#x2605;" />
                                                <Setter Property="Foreground" Value="{DynamicResource MagentaBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>

                        <!-- Re-authenticate (visible when SessionExpired) -->
                        <Button Content="Re-authenticate"
                                Command="{Binding DataContext.ReauthenticateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="12,6" Margin="0,0,8,0"
                                Background="{DynamicResource RowExpiredAccentBrush}"
                                Foreground="{DynamicResource NavyBrush}"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Visibility="{Binding SessionExpired, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Friends — opens per-account follow modal. Disabled when expired. -->
                        <Button Content="Friends"
                                Command="{Binding DataContext.OpenFriendFollowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="10,6" Margin="0,0,8,0"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11"
                                ToolTip="See this account's friends and follow one into their server (works for public + private)."
                                IsEnabled="{Binding SessionExpired, Converter={StaticResource InverseBoolConverter}}" />

                        <!-- Per-account game picker. Empty-state hint overlays the ComboBox until
                             at least one game is in the library, otherwise it looks broken.
                             MinWidth tuned down from 200 to give the name column room to breathe;
                             ComboBox grows naturally if the row width allows. -->
                        <Grid Margin="0,0,8,0" MinWidth="160" VerticalAlignment="Center">
                            <ComboBox ItemsSource="{Binding DataContext.AvailableGames, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding SelectedGame}"
                                      DisplayMemberPath="Name"
                                      VerticalAlignment="Center"
                                      SelectionChanged="OnGameComboBoxSelectionChanged"
                                      ToolTip="Game to launch this account into, or '(Paste a link...)' for a one-shot link." />
                            <TextBlock Text="Add games with the Games button"
                                       FontSize="11"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Opacity="0.85"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       Margin="10,0,30,0"
                                       Visibility="{Binding DataContext.AvailableGames.Count, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ZeroToVisibilityConverter}}" />
                        </Grid>

                        <!-- Per-account FPS cap. ComboBox is populated with static items; code-behind
                             handles Loaded (initial selection) and SelectionChanged (persist + route to VM).
                             Tag on each item carries the int value (or x:Null for "no cap"). -->
                        <ComboBox
                            Width="120"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            SelectionChanged="FpsCombo_SelectionChanged"
                            Loaded="FpsCombo_Loaded"
                            ToolTip="FPS cap applied at launch (DFIntTaskSchedulerTargetFps + GlobalBasicSettings FramerateCap)">
                            <ComboBoxItem Content="— FPS"         Tag="{x:Null}" />
                            <ComboBoxItem Content="20 FPS"        Tag="20" />
                            <ComboBoxItem Content="30 FPS"        Tag="30" />
                            <ComboBoxItem Content="45 FPS"        Tag="45" />
                            <ComboBoxItem Content="60 FPS"        Tag="60" />
                            <ComboBoxItem Content="90 FPS"        Tag="90" />
                            <ComboBoxItem Content="120 FPS"       Tag="120" />
                            <ComboBoxItem Content="144 FPS"       Tag="144" />
                            <ComboBoxItem Content="165 FPS"       Tag="165" />
                            <ComboBoxItem Content="240 FPS"       Tag="240" />
                            <ComboBoxItem Content="Unlimited FPS" Tag="9999" />
                        </ComboBox>

                        <!-- Launch As (hidden while running — Stop takes its place) -->
                        <Button Content="Launch As"
                                Command="{Binding DataContext.LaunchAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="{DynamicResource CyanBrush}"
                                Foreground="{DynamicResource NavyBrush}"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                IsEnabled="{Binding IsLaunching, Converter={StaticResource InverseBoolConverter}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Stop (visible while running) -->
                        <Button Content="Stop"
                                Command="{Binding DataContext.StopAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="{DynamicResource MagentaBrush}"
                                Foreground="{DynamicResource WhiteBrush}"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                ToolTip="Close the Roblox window for this account."
                                Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Remove -->
                        <Button Content="Remove"
                                Command="{Binding DataContext.RemoveAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="10,6"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1" />
                    </StackPanel>
                </Grid>
            </Border>
            </StackPanel>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- TitleBar -->
            <RowDefinition Height="Auto" />  <!-- Header -->
            <RowDefinition Height="Auto" />  <!-- StatusBanner -->
            <RowDefinition Height="Auto" />  <!-- Compat banner -->
            <RowDefinition Height="Auto" />  <!-- Bloxstrap warning banner -->
            <RowDefinition Height="*" />     <!-- Account list -->
            <RowDefinition Height="Auto" />  <!-- Footer -->
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="RORORO"
                     ShowMaximize="True"
                     ShowMinimize="True"
                     ShowClose="True">
            <ui:TitleBar.Icon>
                <!-- 64x64 PNG source so WPF downsamples cleanly. Width/Height shrunk + center
                     alignment so the icon never collides with the title bar's icon-slot height
                     (the WPF-UI TitleBar slot is shorter than 18px on some Win11 chrome configs). -->
                <ui:ImageIcon Source="/ROROROblox.App;component/Tray/Resources/tray-on-titlebar.png"
                              Width="16" Height="16"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Header — two rows so the title block can never be clipped by the action buttons.
             Hidden entirely in compact mode (the bottom-bar Compact toggle is the way back out). -->
        <Border Grid.Row="1" Padding="24,18" Background="{DynamicResource NavyBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCompact}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 1: title block (left) + primary actions (right). -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="RORORO"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource CyanBrush}" />
                            <TextBlock Text=" / "
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource MagentaBrush}" />
                            <TextBlock Text="Accounts"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource WhiteBrush}" />
                        </StackPanel>
                        <TextBlock Text="Run multiple Roblox clients side by side. Add a saved account, click Launch As to open it."
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="+ Add Account"
                                Command="{Binding AddAccountCommand}"
                                Padding="16,8"
                                Background="{DynamicResource CyanBrush}"
                                Foreground="{DynamicResource NavyBrush}"
                                BorderThickness="0"
                                FontWeight="Bold"
                                FontSize="13" />
                    </StackPanel>
                </Grid>

                <!-- Row 2: toolbar — secondary nav (left) + batch-launch CTAs (right). -->
                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="&#x2699; Settings"
                                Command="{Binding OpenPreferencesCommand}"
                                Padding="10,6" Margin="0,0,6,0"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11"
                                ToolTip="Run on login, launch main on startup, theme picker, build a custom theme." />
                        <Button Content="About"
                                Command="{Binding OpenAboutCommand}"
                                Padding="10,6" Margin="0,0,6,0"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11"
                                ToolTip="Version, links, license." />
                        <Button Content="History"
                                Command="{Binding OpenHistoryCommand}"
                                Padding="10,6" Margin="0,0,6,0"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11"
                                ToolTip="Recent sessions per account: what game/server, when, how long." />
                        <Button Content="Diagnostics"
                                Command="{Binding OpenDiagnosticsCommand}"
                                Padding="10,6" Margin="0,0,6,0"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11"
                                ToolTip="System health, Roblox + WebView2 versions, log location." />
                        <Button Content="Games"
                                Command="{Binding OpenSettingsCommand}"
                                Padding="10,6" Margin="0,0,6,0"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11"
                                ToolTip="Manage saved games for the per-row launch picker." />
                    </StackPanel>

                    <!-- v1.3.x — default-game widget. Lives between the left-side nav and the
                         right-side launch CTAs. Click toggles a popup of saved games; pick one
                         to set it default. Empty state hides the widget and shows a one-click
                         "Add games" entry in the same slot. Compact mode hides the entire header
                         (line 547), so the widget gets compact-mode hide for free. -->
                    <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Filled state: ToggleButton + dropdown Popup. -->
                        <ToggleButton x:Name="DefaultGameWidget"
                                      MinWidth="220" MaxWidth="340"
                                      Padding="12,6"
                                      Background="{DynamicResource RowBgBrush}"
                                      Foreground="{DynamicResource WhiteBrush}"
                                      BorderBrush="{DynamicResource CyanBrush}"
                                      BorderThickness="1"
                                      Cursor="Hand"
                                      ToolTip="The default game Launch As uses when no per-row pick is set. Click to change."
                                      IsChecked="{Binding IsDefaultGameDropdownOpen, Mode=TwoWay}">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WidgetGames.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Cyan default dot. -->
                                <Ellipse Grid.Column="0"
                                         Width="8" Height="8"
                                         Fill="{DynamicResource CyanBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0" />

                                <!-- Mono-micro label. Brand: uppercase + tracking, magenta tint. -->
                                <TextBlock Grid.Column="1"
                                           Text="DEFAULT"
                                           FontFamily="JetBrains Mono, Cascadia Mono, Consolas"
                                           FontSize="9"
                                           Foreground="{DynamicResource MagentaBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />

                                <!-- The current default game's display name (LocalName ?? Name).
                                     Bound to MainViewModel.DefaultGameDisplay. -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DefaultGameDisplay}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource WhiteBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Chevron — flips visually via the ToggleButton's IsChecked
                                     state if a future style upgrade wants it. For v1.3.x just
                                     a static down-pointing glyph. -->
                                <TextBlock Grid.Column="3"
                                           Text="&#x25BE;"
                                           FontSize="12"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />
                            </Grid>
                        </ToggleButton>

                        <!-- Empty state: replaces the toggle when no games are saved.
                             One click → Games settings sheet (same as the toolbar Games button). -->
                        <Button Content="No saved games yet — Add a game"
                                Command="{Binding OpenSettingsCommand}"
                                MinWidth="220" MaxWidth="340"
                                Padding="12,6"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                FontSize="11"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WidgetGames.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Dropdown popup: ListBox of saved games + Manage games footer. Closes on
                             pick (StaysOpen=False) or on outside-click. -->
                        <Popup IsOpen="{Binding ElementName=DefaultGameWidget, Path=IsChecked}"
                               PlacementTarget="{Binding ElementName=DefaultGameWidget}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{DynamicResource RowBgBrush}"
                                    BorderBrush="{DynamicResource CyanBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="4"
                                    Margin="0,4,0,0"
                                    MinWidth="280" MaxWidth="360">
                                <DockPanel>
                                    <Button DockPanel.Dock="Bottom"
                                            Content="Manage games…"
                                            Command="{Binding OpenSettingsCommand}"
                                            Padding="10,6"
                                            Margin="0,4,0,0"
                                            HorizontalContentAlignment="Left"
                                            Background="{DynamicResource NavyBrush}"
                                            Foreground="{DynamicResource MutedTextBrush}"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="0,1,0,0"
                                            FontSize="11"
                                            Cursor="Hand" />
                                    <ListBox ItemsSource="{Binding WidgetGames}"
                                             SelectedItem="{Binding CurrentDefaultGame, Mode=OneWay}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             MaxHeight="280"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,1" />
                                                <Setter Property="Cursor" Value="Hand" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Button Padding="10,6"
                                                        HorizontalContentAlignment="Stretch"
                                                        Background="Transparent"
                                                        Foreground="{DynamicResource WhiteBrush}"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.SetDefaultGameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Cyan dot for the current default; transparent otherwise. -->
                                                        <Ellipse Grid.Column="0"
                                                                 Width="6" Height="6"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,8,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="Transparent" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                                            <Setter Property="Fill" Value="{DynamicResource CyanBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>

                                                        <!-- Display name: LocalName ?? Name. Item 8 wires the
                                                             RenderName binding pattern in full; for the widget
                                                             we use a small inline converter via priority binding. -->
                                                        <TextBlock Grid.Column="1"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource WhiteBrush}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Text>
                                                                <PriorityBinding>
                                                                    <Binding Path="LocalName" />
                                                                    <Binding Path="Name" />
                                                                </PriorityBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>

                                                        <!-- DEFAULT pill on the current default. -->
                                                        <Border Grid.Column="2"
                                                                Background="{DynamicResource MagentaBrush}"
                                                                CornerRadius="2"
                                                                Padding="5,1"
                                                                Margin="8,0,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="DEFAULT"
                                                                       FontFamily="JetBrains Mono, Cascadia Mono, Consolas"
                                                                       FontSize="8"
                                                                       FontWeight="Bold"
                                                                       Foreground="{DynamicResource WhiteBrush}" />
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Launch multiple"
                                Command="{Binding LaunchAllCommand}"
                                Padding="14,6" Margin="0,0,8,0"
                                Background="{DynamicResource NavyBrush}"
                                Foreground="{DynamicResource WhiteBrush}"
                                BorderBrush="{DynamicResource CyanBrush}"
                                BorderThickness="1"
                                FontSize="12"
                                FontWeight="SemiBold"
                                ToolTip="Launch every selected account into its own per-row game, throttled 1.5s apart. Use the dot next to each account's status to deselect." />
                        <Button Content="Private server"
                                Command="{Binding OpenSquadLaunchCommand}"
                                Padding="14,6"
                                Background="{DynamicResource MagentaBrush}"
                                Foreground="{DynamicResource WhiteBrush}"
                                BorderThickness="0"
                                FontSize="12"
                                FontWeight="SemiBold"
                                ToolTip="Send every selected account into the same Roblox private server. Use the dot next to each account's status to deselect." />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Status banner -->
        <Border Grid.Row="2" Padding="24,8"
                Background="{DynamicResource RowBgBrush}"
                Visibility="{Binding StatusBanner, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusBanner}"
                       FontSize="11"
                       Foreground="{DynamicResource WhiteBrush}" />
        </Border>

        <!-- Roblox compat banner (drift detection per spec §7.1) -->
        <Border Grid.Row="3" Padding="24,10"
                Background="{DynamicResource RowExpiredBgBrush}"
                BorderBrush="{DynamicResource RowExpiredAccentBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding RobloxCompatBanner, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding RobloxCompatBanner}"
                       FontSize="11"
                       Foreground="{DynamicResource RowExpiredAccentBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Bloxstrap warning banner — visible when BloxstrapWarningVisible is true.
             Warm amber tone distinct from the red-ish compat banner above it. -->
        <Border Grid.Row="4"
                Background="#3F3000"
                BorderBrush="#8F7000"
                BorderThickness="0,0,0,1"
                Padding="16,10"
                Visibility="{Binding BloxstrapWarningVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <Button
                    DockPanel.Dock="Right"
                    Content="Dismiss"
                    Margin="12,0,0,0"
                    Command="{Binding DismissBloxstrapWarningCommand}" />
                <TextBlock
                    VerticalAlignment="Center"
                    TextWrapping="Wrap"
                    Foreground="#FFE3A6"
                    Text="Bloxstrap is set as your Roblox launcher — it will override per-account FPS. Set FPS in Bloxstrap to match." />
            </DockPanel>
        </Border>

        <!-- Row 5 — switches between full account list (normal) and compact strip (compact mode). -->
        <Grid Grid.Row="5">
            <!-- Full account list — visible when NOT compact. Horizontal scroll is a
                 No horizontal scrollbar — Window.MinWidth=860 floors the window wide enough
                 that all row content fits. If the user shrinks below that we'd rather clip /
                 trim the name (TextTrimming on DisplayName handles long names) than let a
                 horizontal scrollbar steal vertical space. Compact mode is the right answer
                 for "I want this small." -->
            <ScrollViewer Padding="24,16,24,16"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <Grid Grid.IsSharedSizeScope="True">
                    <ItemsControl ItemsSource="{Binding Accounts}" />

                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding Accounts.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                        <TextBlock Text="No saved accounts yet."
                                   FontSize="14"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Click + Add Account to log in to your first Roblox account."
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"
                                   Opacity="0.7" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Compact strip — visible ONLY when compact. Three layers: live-rows list,
                 then a content overlay with the 3-state empty area when nothing's running. -->
            <Border Padding="14,14,14,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <!-- Live-running rows — only renders when there's at least one. -->
                    <ItemsControl ItemsSource="{Binding CompactRows}"
                                  ItemTemplate="{StaticResource CompactAccountTemplate}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCompactRows}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>

                    <!-- Empty state — three-variant CTA so compact never looks broken. -->
                    <ContentControl HorizontalAlignment="Stretch" VerticalAlignment="Center">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCompactRows}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>

                        <!-- Variant A — main is set + idle: "Start [Username]" CTA -->
                        <Grid>
                            <StackPanel HorizontalAlignment="Stretch">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CompactEmptyKind}" Value="StartMain">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="No Roblox running."
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8" />
                                <Button Command="{Binding StartMainCommand}"
                                        Padding="14,10"
                                        Background="{DynamicResource CyanBrush}"
                                        Foreground="{DynamicResource NavyBrush}"
                                        BorderThickness="0"
                                        FontWeight="SemiBold"
                                        FontSize="13"
                                        HorizontalAlignment="Stretch"
                                        ToolTip="Launch your main account into its current per-row game.">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#x25B6; Start " />
                                        <TextBlock Text="{Binding MainAccount.DisplayName, FallbackValue='main'}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Variant B — accounts exist but no main set -->
                            <StackPanel HorizontalAlignment="Stretch">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CompactEmptyKind}" Value="NoMainPicked">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="No main account picked."
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WhiteBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="Expand and click the &#x2606; on a row to set one."
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10" />
                                <Button Command="{Binding ToggleCompactCommand}"
                                        Content="Expand"
                                        Padding="14,8"
                                        Background="{DynamicResource NavyBrush}"
                                        Foreground="{DynamicResource WhiteBrush}"
                                        BorderBrush="{DynamicResource CyanBrush}"
                                        BorderThickness="1"
                                        FontWeight="SemiBold"
                                        HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Variant C — no accounts saved at all -->
                            <StackPanel HorizontalAlignment="Stretch">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CompactEmptyKind}" Value="NoAccounts">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="No accounts saved."
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WhiteBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8" />
                                <Button Command="{Binding AddAccountCommand}"
                                        Content="+ Add your first account"
                                        Padding="14,10"
                                        Background="{DynamicResource CyanBrush}"
                                        Foreground="{DynamicResource NavyBrush}"
                                        BorderThickness="0"
                                        FontWeight="SemiBold"
                                        FontSize="12"
                                        HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>
                    </ContentControl>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="6" Padding="16,8" Background="{DynamicResource NavyBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Live process count + green/grey dot. -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7"
                             VerticalAlignment="Center" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#4FE08C" />
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LiveProcessCount}" Value="0">
                                        <Setter Property="Fill">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#4A5C70" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding LiveProcessSummary}"
                               FontSize="11"
                               Foreground="{DynamicResource WhiteBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Compact / Expand toggle, sitting next to the count on the left. -->
                <Button Grid.Column="1"
                        Command="{Binding ToggleCompactCommand}"
                        Content="{Binding CompactToggleLabel}"
                        Padding="10,4" Margin="14,0,0,0"
                        Background="Transparent"
                        Foreground="{DynamicResource MutedTextBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        FontSize="10"
                        VerticalAlignment="Center"
                        ToolTip="Shrink to a small ops view that only shows running accounts. Click again to expand." />

                <TextBlock Grid.Column="2"
                           Text="Multi-launcher for Windows. A 626 Labs product."
                           FontSize="10"
                           Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <!-- Tagline disappears in compact mode — not enough room for it. -->
                                <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Column="3"
                           Text="X minimizes to tray. Quit from the tray to exit."
                           FontSize="10"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Opacity="0.7"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Drag-ghost preview Popup. Positioned absolute (screen coords) and repositioned on
             every PreviewDragOver during a drag-to-reorder gesture. Uses a RenderTargetBitmap
             snapshot rather than VisualBrush of the live row — adorners + live VisualBrushes
             both have known WPF rendering issues during a modal drag operation; the bitmap+Popup
             combination renders reliably across versions. -->
        <Popup x:Name="DragGhostPopup"
               Placement="Absolute"
               AllowsTransparency="True"
               IsOpen="False"
               AllowDrop="False">
            <Border Opacity="0.78" IsHitTestVisible="False" Background="Transparent">
                <Image x:Name="DragGhostImage"
                       Stretch="None"
                       IsHitTestVisible="False" />
            </Border>
        </Popup>
    </Grid>
</ui:FluentWindow>
