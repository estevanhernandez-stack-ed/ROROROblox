# ROROROblox — minimal .gitignore (item 2 will expand this when scaffolding the real solution)

# Throwaway spike — verification gate, not deliverable code
spike/

# .NET build outputs
bin/
obj/

# IDE / tooling
.vs/
.qodo/
.idea/
*.user
*.suo
# Qodo IDE auto-regenerates a legacy .sln next to our .slnx — ignore so commits stay clean.
# Build with: dotnet build ROROROblox.slnx
ROROROblox.sln

# Per-user Claude Code state (project-shared lives in .claude/settings.json if needed)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Secrets — DPAPI envelope file (per-machine), private-key bundles, env files
accounts.dat
last-update-check.txt
webview2-data/
# v1.2 Discord clan-coordination — defense-in-depth (these live in %LOCALAPPDATA%, but
# a developer accidentally placing one in the repo root is exactly the secret leak we want
# to catch at pre-commit time). discord-config.json holds the clan webhook URL on a
# per-machine basis; webhook URLs are credentials in disguise (anyone with one can post).
discord-config.json
discord-config.json.corrupt-*
discord.log
*.pfx
*.p12
*.key
*.pem
# Public cert produced by scripts/generate-dev-cert.ps1 next to the .pfx. Distributed with each
# sideload release on GitHub Releases (testers import it before installing the .msix); not tracked.
dev-cert.cer
.env
.env.local

# MSIX build outputs (scripts/build-msix.ps1 publishes here)
dist/

# Velopack release outputs
Releases/
*.nupkg

# Tray-icon debug output -- scripts/generate-tray-icons.ps1 emits standalone PNGs at
# small sizes (16/24/32) into Tray/Resources/.debug/ for visual inspection. Not shipped.
src/ROROROblox.App/Tray/Resources/.debug/

# vibe-iterate plugin state (config, atlas, radar cache) — local, flash-drive convention
.vibe-iterate/

# OS noise
Thumbs.db
.DS_Store
